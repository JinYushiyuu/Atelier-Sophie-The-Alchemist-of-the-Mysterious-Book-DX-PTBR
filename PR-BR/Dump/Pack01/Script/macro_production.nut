		ECT_CONTRAST_SET, CONTRAST_TYPE_FIELDMAP, CONTRAST_MODE_BLACK_IN, 50, 

		ECT_CAMERA_C_TYPE_SET, CAMERA_C_MANUAL, 
		ECT_CAMERA_FOV_SET, 3500,
		ECT_CAMERA_EYEAT_POS_SET, OBJ_TYPE_CHARA_SELF, CHARA_SOPHIE, MODEL_OFFSET_BODY, 0,10,0, OBJ_TYPE_CHARA_SELF, CHARA_SOPHIE, MODEL_OFFSET_BODY, 0,100,200, 
