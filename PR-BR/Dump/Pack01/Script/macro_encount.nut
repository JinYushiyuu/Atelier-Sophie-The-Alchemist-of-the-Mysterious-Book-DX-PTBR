		ECT_CAMERA_QUAKE_SET, CAMERA_QUAKE_Y_XYZ_NORMAL_MIDDLE00, 300,
		ECT_EVENT_SET_POST_EFFECT, -1, -1, 300, POST_EFFECT_BLUR, CURVE_LINEAR, -20, 0, 50, 
		ECT_EVENT_POST_EFFECT_BLUR_SET_TARGET, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_BODY, 0,0,0,
		
