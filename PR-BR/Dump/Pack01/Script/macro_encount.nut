		ECT_EVENT_SET_POST_EFFECT, -1, 1, 1000, POST_EFFECT_GAMMA, CURVE_10, CURVE_10, CURVE_10, CURVE_LINEAR, 
		ECT_EVENT_POST_EFFECT_BLUR_SET_TARGET, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,0,0,

		ECT_CHARA_MOTION_SET, s32PlayerTag, MOTION_F_BATTLE, 0, 900, 
