		ECT_CHARA_MOTION_SET, s32TargetCharaTag, MOTION_ATTACK03, 3, 0, 
		ECT_CHARA_MOTION_WAIT, s32TargetCharaTag,
		ECT_MACRO_CHARA_WAIT, s32TargetCharaTag,

		ECT_CAMERA_AT_MOVE_SET, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,125,400, MOVE_FIX_ACCEL, 60, 100, 
		ECT_CAMERA_EYE_MOVE_SET, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, -100,50,850, MOVE_FIX_ACCEL, 60, 100,

