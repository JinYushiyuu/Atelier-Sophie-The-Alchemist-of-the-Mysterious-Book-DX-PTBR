		ECT_FIELDMAP_CHARA_COLLISION_FLAG, s32TargetCharaTag, 1, 1, 1, 2,
		
		ECT_END
	];
	
	foreach (idx, val in temp) {
		SQ.copyProgramMacro(val, idx);
	}
	
	SQ.execProgramMacro("forceEncountDragon");
	
	return;
}

