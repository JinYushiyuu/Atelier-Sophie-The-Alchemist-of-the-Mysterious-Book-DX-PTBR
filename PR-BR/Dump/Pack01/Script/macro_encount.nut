		ECT_CHARA_MOTION_SET_SPEED, s32TargetCharaTag, 50, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 1, EFF_TYPE_GEOMETRY, 424, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,3,150, 1000, 0, 0,0,0, 1300,1300,1300, 254,37,0, 0, 0, -1, -1, 

		ECT_CHARA_POS_SET, s32PlayerTag, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,3,500, 
		ECT_CHARA_ROT_SET_TARGET, s32PlayerTag, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,0,0,

		ECT_MACRO_TIME_WAIT, 50, 

//ゴゴゴゴSEここに入れる
		ECT_CHARA_SE_NON_STREAM_PLAY, s32TargetCharaTag, SE_EXPLOSION05, 0, 40, 2000, 0, 
		ECT_CHARA_SE_NON_STREAM_PLAY, s32TargetCharaTag, SE_EXPLOSION05, 0, 40, 10700, -1000,
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 2, EFF_TYPE_GEOMETRY, 455, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_BODY, 0,0,0, 1000, 0, 0,0,0, 800,500,800, 0,0,0, 128, 0, -1, -1, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 3, EFF_TYPE_GEOMETRY, 49, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,3,150, 1000, 0, 0,0,0, 1300,1300,1300, 254,78,0, 128, -1, -1, -1, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 4, EFF_TYPE_GEOMETRY, 12, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,3,150, 1000, 0, 9000,0,0, 250,250,250, 254,123,104, 0, -1, -1, -1, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 5, EFF_TYPE_GEOMETRY, 11, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,3,150, 1000, 0, 9000,0,0, 175,175,175, 255,160,160, 0, -1, -1, -1, 
		ECT_CHARA_TIME_WAIT, s32TargetCharaTag, 3, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 6, EFF_TYPE_GEOMETRY, 112, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,3,150, 1000, 0, 0,0,0, 400,400,400, 255,64,32, 0, -1, -1, -1, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 7, EFF_TYPE_GEOMETRY, 292, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,3,150, 1000, 0, 0,0,0, 200,175,200, 0,0,0, 0, -1, -1, -1, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 8, EFF_TYPE_GEOMETRY, 181, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,-5,150, 1000, 0, 0,0,0, 300,300,300, 0,0,0, 0, -1, -1, -1, 
		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 9, EFF_TYPE_GEOMETRY, 105, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 0,30,150, 1000, 0, 0,0,0, 400,300,400, 0,0,0, 128, -1, -1, -1, 

