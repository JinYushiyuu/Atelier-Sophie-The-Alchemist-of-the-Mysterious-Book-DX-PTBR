		ECT_CHARA_EFF_ADD, s32TargetCharaTag, 0, EFF_TYPE_GEOMETRY, 105, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_FOOT, 100,0,250, 50, 0, 0,0,0, 100,100,100, 140,137,128, 128, -1, -1, -1, 
		ECT_CHARA_MOTION_WAIT, s32TargetCharaTag,
