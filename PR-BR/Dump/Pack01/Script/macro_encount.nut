		ECT_CAMERA_EYE_MOVE_SET, OBJ_TYPE_CHARA_SELF, s32TargetCharaTag, MODEL_OFFSET_BODY, 0,-200,1000, MOVE_FIX_ACCEL, 200, 100, 
