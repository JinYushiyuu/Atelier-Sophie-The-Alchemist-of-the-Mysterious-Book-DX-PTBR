    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_SP_02" chara_tag="NPC23B" voice_no1="-1" message1="&lt;CLGR&gt;Learned more about monsters.&lt;CLNR&gt;"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC27A_00" chara_tag="NPC27A" name_tag="NPC27A_03" voice_no1="11743" message1="I'm checking to see if there's a new book out."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC27A_10" chara_tag="NPC27A" name_tag="NPC27A_03" voice_no1="11743" message1="I like to read a whole series at once, so I buy them all first."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC27A_20" chara_tag="NPC27A" name_tag="NPC27A_03" voice_no1="11743" message1="I like novels with illustrations. I find them very easy to read."/>
