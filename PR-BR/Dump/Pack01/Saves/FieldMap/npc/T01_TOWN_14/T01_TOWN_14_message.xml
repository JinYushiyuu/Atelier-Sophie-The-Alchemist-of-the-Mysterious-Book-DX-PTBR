    <T01_TOWN_14_message message_data="TOWN_14_NPC23A_00" chara_tag="NPC23A" name_tag="NPC23A_03" voice_no1="11772" message1="It's said that some books are fun to read from end to beginning, but..." next_message_tag="TOWN_14_NPC23A_01"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23A_01" chara_tag="NPC23A" name_tag="NPC23A_03" voice_no1="-1" message1="I like mixing up all the pages, and arranging them into my own story."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23A_10" chara_tag="NPC23A" name_tag="NPC23A_03" voice_no1="11772" message1="I want to read as many books as possible during my life, so I'm learning how to speed read." next_message_tag="TOWN_14_NPC23A_11"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23A_11" chara_tag="NPC23A" name_tag="NPC23A_03" voice_no1="-1" message1="But I don't seem to be getting any better. It might be easier for me to just live longer instead."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23A_20" chara_tag="NPC23A" name_tag="NPC23A_03" voice_no1="11772" message1="I'm always afraid of finishing a really good book, so I start from the beginning over and over again." next_message_tag="TOWN_14_NPC23A_21"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23A_21" chara_tag="NPC23A" name_tag="NPC23A_03" voice_no1="-1" message1="Because of that, I end up reading the first page more than a hundred times."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_00" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="11739" message1="I'm researching the ecology of monsters." next_message_tag="TOWN_14_NPC23B_01"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_01" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="-1" message1="If you have questions, come ask me anytime."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_10" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="11739" message1="It seems many monsters are affected by the current time and weather." next_message_tag="TOWN_14_NPC23B_11"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_11" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="-1" message1="Rain and night are good examples. You should be a little more careful during times like this."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_20" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="11739" message1="It's well known that most monsters have some sort of weakness." next_message_tag="TOWN_14_NPC23B_21"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_21" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="-1" message1="They also have some patterns to their actions. For example, when their strength is low, or a certain time passes after starting combat..."/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_SP" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="11739" message1="Are you researching monsters? I'm doing that too..." next_message_tag="TOWN_14_NPC23B_SP_00"/>
    <T01_TOWN_14_message message_data="TOWN_14_NPC23B_SP_00" chara_tag="NPC23B" name_tag="NPC23B_01" voice_no1="-1" message1="Would you like to trade information?" next_message_tag="TOWN_14_NPC23B_SP_01"/>
