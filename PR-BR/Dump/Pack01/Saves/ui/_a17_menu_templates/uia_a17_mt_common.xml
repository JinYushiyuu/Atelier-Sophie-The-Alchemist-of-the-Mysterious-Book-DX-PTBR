<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uia.dtd">
<root>
	<anim name="anm_menu_fade_in">
    	<curve attr="color">
			<key time="0.0"		value="255,255,255,0"/>
			<key time="0.25"	value="255,255,255,255"/>
		</curve>
	</anim>

	<anim name="anm_menu_fade_out">
    	<curve attr="color">
			<key time="0.0"		value="255,255,255,255"/>
			<key time="0.25"	value="255,255,255,0"/>
		</curve>
	</anim>
    <anim name="anm_menu_rotate">
        <curve attr="rot">
            <key time="0.0"		value="0,0,0"/>
            <key time="1.0"		value="0,0,360"/>
        </curve>
    </anim>
    <anim name="anm_menu_selected">
        <curve attr="pos">
            <key time="0.0"		value="0,0,0"/>
            <key time="0.25"	value="0,0,-20"/>
        </curve>
    </anim>

    <anim name="anm_menu_cursor_move">
        <curve attr="image_no">
            <key time="0.0"		value="0"/>
            <key time="0.1"	    value="1"/>
            <key time="0.2"     value="2"/>
        </curve>
    </anim>
</root>

