		</image>
	</node>
	<anim_ctrl viewer_key_assign="0" loop="true" play="true">
		<bind_node node="A" anim="anm_linear_pos"/>
		<bind_node node="B" anim="anm_spline_pos" delay="0.50"/>
		<bind_node node="C" anim="anm_spline_pos_edging" delay="1.00"/>
		<bind_node node="D" anim="anm_spline_pos_easing" delay="1.50"/>
	</anim_ctrl>
