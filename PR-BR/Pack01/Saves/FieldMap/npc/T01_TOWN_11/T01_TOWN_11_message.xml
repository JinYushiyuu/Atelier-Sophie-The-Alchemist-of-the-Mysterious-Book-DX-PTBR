    <T01_TOWN_11_message message_data="TOWN_11_NPC21A_10" chara_tag="NPC21A" name_tag="NPC21A" voice_no1="11803" message1="Apparently in the past, it was said that alcohol was a gift from God..." next_message_tag="TOWN_11_NPC21A_11"/>
