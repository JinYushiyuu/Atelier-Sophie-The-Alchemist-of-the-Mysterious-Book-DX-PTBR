    <T01_TOWN_11_message message_data="TOWN_11_NPC21A_20" chara_tag="NPC21A" name_tag="NPC21A" voice_no1="11803" message1="When you grow up, there's less things that seem fun." next_message_tag="TOWN_11_NPC21A_21"/>
