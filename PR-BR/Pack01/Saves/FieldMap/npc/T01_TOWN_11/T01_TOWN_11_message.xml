    <T01_TOWN_11_message message_data="TOWN_11_NPC00A_20" chara_tag="NPC00A" name_tag="NPC00A" voice_no1="11748" message1="Lately, I've been thinking of orders that would let me sit here a little longer than usual."/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26B_00" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="I'm trying to think of ways to efficiently finish lots of requests, but..." next_message_tag="TOWN_11_NPC26B_01"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26B_01" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="I think I'm the type who needs to go one by one, completing them thoroughly."/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26B_10" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="It's great that I can accept more difficult requests now, but..." next_message_tag="TOWN_11_NPC26B_11"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26B_11" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="Some of them really are too hard. It takes a different kind of courage to refuse them."/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26B_20" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="The only requests I can really do are the ones to deliver materials..." next_message_tag="TOWN_11_NPC26B_21"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26B_21" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="But the more capable you prove yourself to be, the less easy requests like that you see."/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC27A_00" chara_tag="NPC27A" name_tag="NPC27A_03" voice_no1="-1" message1="The weekdays don't really have any special events..." next_message_tag="TOWN_11_NPC27A_01"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC27A_01" chara_tag="NPC27A" name_tag="NPC27A_03" voice_no1="-1" message1="It's actually good, since you can immerse yourself in your own work."/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC27A_10" chara_tag="NPC27A" name_tag="NPC27A_03" voice_no1="-1" message1="It kind of makes your curious when people aren't in their usual places, right?"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC27A_20" chara_tag="NPC27A" name_tag="NPC27A_03" voice_no1="-1" message1="Hm, where should I go today..."/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26A_00" chara_tag="NPC26A" name_tag="NPC26A_01" voice_no1="-1" message1="Ah... Such a gentle interior, and that faint, fleeting feeling..." next_message_tag="TOWN_11_NPC26A_01"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26A_01" chara_tag="NPC26A" name_tag="NPC26A_01" voice_no1="-1" message1="That atmosphere has captured my heart, and won't let go..."/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26A_10" chara_tag="NPC26A" name_tag="NPC26A_01" voice_no1="-1" message1="Hmm, maybe... I just don't have the right air." next_message_tag="TOWN_11_NPC26A_11"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26A_11" chara_tag="NPC26A" name_tag="NPC26A_01" voice_no1="-1" message1="What about learning from someone? Like Pamela?"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26A_20" chara_tag="NPC26A" name_tag="NPC26A_01" voice_no1="-1" message1="Hehe, I can't say enough today either... It's never enough." next_message_tag="TOWN_11_NPC26A_21"/>
    <T01_TOWN_11_message message_data="TOWN_11_NPC26A_21" chara_tag="NPC26A" name_tag="NPC26A_01" voice_no1="-1" message1="I couldn't say enough, even if I spent my entire life. Pamela's charm is just that deep."/>
