<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uia.dtd">
<root>
  <anim name="anm_wheel_rot">
    <curve attr="rot" >
      <key time="0.0"	value="0,0,0"/>
      <key time="0.3"	value="0,0,90"/>
    </curve>
  </anim>
  <anim name="anm_wheel_blink">
    <curve attr="color">
      <key time="0.0"		value="255,255,255,255"/>
      <key time="1.0"		value="255,255,255,128"/>
      <key time="2.0"		value="255,255,255,255"/>
    </curve>
  </anim>
  <anim name="anm_caption_slide_in">
    <curve attr="color">
      <key time="0.0"		value="255,255,255,  0"/>
      <key time="0.25"	value="255,255,255,255"/>
    </curve>
    <curve attr="pos">
      <key time="0.0"	value="110,0,0"/>
      <key time="0.25"	value="0,0,0"/>
    </curve>
  </anim>
    <anim name="anm_caption_slide_in2">
    <curve attr="color">
      <key time="0.0"		value="255,255,255,  0"/>
      <key time="0.25"	value="255,255,255,255"/>
    </curve>
    <curve attr="pos">
      <key time="0.0"	value="-110,0,0"/>
      <key time="0.25"	value="0,0,0"/>
    </curve>
  </anim>
  <anim name="anm_caption_roll_in">
    <curve attr="color">
      <key time="0.0"		value="255,255,255,  0"/>
      <key time="0.25"	value="255,255,255,255"/>
    </curve>
    <curve attr="rot">
      <key time="0.0"	value="-90,0,0"/>
      <key time="0.25"	value="0,0,0"/>
    </curve>
  </anim>
  
</root>

