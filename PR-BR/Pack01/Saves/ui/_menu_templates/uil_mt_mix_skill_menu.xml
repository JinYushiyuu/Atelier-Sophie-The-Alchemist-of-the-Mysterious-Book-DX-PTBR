<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uil.dtd">
<root>
	<!-- スタイルの読み込み -->
	<command load_style="Saves/ui/_menu_templates/uis_mt_common.xml"/>
	<!-- アニメーションの読み込み -->
	<command load_anim="Saves/ui/_menu_templates/uia_mt_common.xml"/>
	<!-- 下地ウィンドウ -->
	<image name="__uimenu_window" size_wh="350.00, 120.00, 0.00" style="common_none_image">
		<!--スクロールバー-->
		<scroll_bar name="__uimenu_scroll_bar" pos_ratio="1,0" pos="-24, 32, 0" size_h="231"/>
		<!-- メニュー項目 -->
		<node name="__uimenu_body" pos="-5,35">
			<!-- メニューカーソル -->
			<node name="__uimenu_cursor" viewer_visible="false">
				<image name="__uimenu_cursor_inactive" pos="30.00, -1.00, -10.00" parent_size_copy_w="true" size_copy_w_offset="-53.00" image_no="0" style="gen_window01_highlight_over" size_h="20.00" scale="1.00, 0.80, 1.00"/>
				<image name="__uimenu_cursor_active" pos="30.00, -1.00, -10.00" parent_size_copy_w="true" size_copy_w_offset="-53.00" image_no="0" style="gen_window01_highlight_on" size_h="10.00" size_wh="297.00, 29.00, 0.00" scale="1.00, 0.80, 1.00">
					<feed pos="5,20"/>
				</image>
				<!-- 明滅アニメーション -->
				<anim_ctrl play="true" loop="true">
					<bind_node node="__uimenu_cursor_active" anim="anm_common_cursor_blink"/>
				</anim_ctrl>
			</node>
			<!-- メニュー項目リスト(この下にMenuItemが連なる) -->
			<node pos="25, 0" name="__uimenu_item_list"/>
		</node>
	</image>
</root>
