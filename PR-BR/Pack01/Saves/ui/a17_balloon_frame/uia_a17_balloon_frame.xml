<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uia.dtd">
<root>
	<anim name="anm_bf_prompt">
		<curve attr="pos" interpolate="spline">
			<key time="0.0"		value="0,-2,0"/>
			<key time="0.6"		value="0, 2,0"/>
			<key time="1.2"		value="0,-2,0"/>
		</curve>
	</anim>
	<anim name="anm_bf_blink">
		<curve attr="color" interpolate="spline">
			<key time="0.0"		value="255,255,255,255"/>
			<key time="0.8"		value="255,255,255,  0"/>
			<key time="1.6"		value="255,255,255,255"/>
		</curve>
	</anim>
</root>

