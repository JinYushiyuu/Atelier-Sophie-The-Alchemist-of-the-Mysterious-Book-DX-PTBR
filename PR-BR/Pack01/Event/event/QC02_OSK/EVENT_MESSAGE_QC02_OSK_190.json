{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_190.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x0,
            "msg_string": "Wow...! There's such a big lake underground!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "I've seen this before, but it's amazing every time..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "It's surprising to see so much water stored up underground."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "But the water in the river comes welling up from underground somewhere too, so I suppose this is very possible."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "It's a really unusual environment, though. The plant we're looking for could be here..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Oh, there!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hey, Oskar! Wait up!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I knew it! Everyone, look at this!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Is that the plant we were looking for?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yeah, that's right. They're really weak to sunlight. That's why they live like this underground."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "Also, there's little temperature change inside a cave. It's pretty much the same environment year round."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "That's why so many plants can live here."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Huh, I didn't know! I might be able to Synthesize something really unusual with them!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "But they're inhabiting such a humid and dark place... Could they be poisonous?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "There's no need to worry about that. I can tell which ones are poisonous and which ones aren't."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "What!? You can do that too, Oskar!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Heh heh heh. I never told you, but I was always checking the things you gathered."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Ah! Now that you mention it... Sometimes things I could have sworn I gathered would just be missing."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Sophie... You didn't think it was strange?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Ahaha... I thought I was just misremembering..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x24,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "I was always removing things that were too dangerous to keep."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "I-I didn't know... Thank you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x17,
            "msg_string": "Not a problem. Anyway, we should start gathering!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Okay!"
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now gather \"<CLGR>Princess Grass<CLNR>\"."
        }
    ]
}