        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yeah, you're right."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Anyway, thank you again. We'll let you know if we see any results."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Okay! I look forward to it!"
