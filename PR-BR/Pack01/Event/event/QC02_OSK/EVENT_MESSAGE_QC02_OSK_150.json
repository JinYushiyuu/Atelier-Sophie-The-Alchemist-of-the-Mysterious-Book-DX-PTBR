            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "I just hope the quality of the vegetables returns to normal..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
