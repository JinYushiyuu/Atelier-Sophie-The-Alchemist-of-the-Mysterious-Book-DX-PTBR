        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Anyway, ignoring him... Thank you, Sophie. You really helped us."
