{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_140.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x0,
            "msg_string": "Hey, Sophie! You came at the perfect time!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Huh? What's up?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "This is really bad! Lately, the vegetables coming to my store are getting less and less lively!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "What!? But they were so lively the other day."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "It's true that lately the quality of our produce is getting worse, and it's troubling..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "I was talking to the vegetables, and they told me that the nutrients in the soil are running out from overuse."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x29,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Really? I wonder if it'll be okay."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "No, at this rate, the vegetables won't last if we wait for the soil to replenish itself."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "That's where you come in. I was wondering if you could make fertilizer with your alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "If the soil has nutrients, the vegetables should be lively again."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I'd like to ask too. I'm desperate enough to ask even a Puni for help now. I want to try whatever's possible."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I-I got it. I'll try."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Thanks, Sophie! Just bring it to the store when you're done. We'll repay you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Okay, I'll do my best for the vegetables!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "We're counting on you!"
        }
    ]
}