{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_280.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "It was around here."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yeah, I'll go talk to them."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hey, it's been a while. I wanted to ask you about the other day."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Why did you lie to us before? If you have a reason for that, can you tell me?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Will he be okay alone?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I think Oskar's the only one who can talk to them."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "...That reminds me, it sounds like you really did believe that Oskar can talk to plants."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Huh? ...Well to be honest, I was really doubtful, but I'm sure it's true to Oskar at least."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ahaha, you really are a nice person."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Am I?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Hm, hm..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "What did you say? ...I didn't know..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "...I got it. Thank you for telling me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "How'd it go?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "They told me all kinds of things. Apparently they're the guardians of the forest."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "The guardians?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yeah. There's lots of rare and valuable plants living deep inside this forest."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Among them, there are some plants that only live here now."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "To protect them, only those deemed worthy are allowed to go to the deeper part."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Really?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "In other words, any humans who try to harvest everything here at the entrance aren't trustworthy, and are poisoned."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Yeah. They said that it's okay for us to go to the deeper part of the forest if we only gather in moderation."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Alright then, let's go!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Yeah. Also, one more thing."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "There's several poisonous plants in this forest too. The poison dust they release is spread around quite a bit."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "We need to walk slowly and softly, otherwise we'll kick up the dust and breathe it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x1a,
            "msg_string": "Waah, really...? Then we need to be careful."
        }
    ]
}