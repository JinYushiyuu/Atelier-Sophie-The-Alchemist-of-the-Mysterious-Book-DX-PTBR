{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_310.ebm",
    "nb_messages": 0x27,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "We did it, we won!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Alright, the Eternal Blossom seems fine. Just take a look."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Wow, it's a really pretty flower seeing it up close."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Yeah. I'm really moved."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x21,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1a,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "So there were flowers like this too? If I had just lived an ordinary life, I would have never known."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "It can't bloom in bright places, after all."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x25,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hey Monika, you should come closer and look..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "...Uu."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "What's wrong, Monika!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5d,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I don't know... I just feel really lightheaded and dizzy all of a sudden..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "...It sounds like Monika's been poisoned. She may have inhaled too much poison dust."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "No way!? And why only Monika!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "I'm not certain, but it may have been when that monster first appeared."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Lots of dust got kicked up by it... I'm sure there was lots of poison dust too."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "It seems the effect of the poison is delayed, so we couldn't tell until now."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Is everyone else okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I think I'm fine."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I don't see any particular issues, so it seems to only be Monika."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Monika... What should we do..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5d,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "...The Eternal Blossom."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Huh?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "The Eternal Blossom is saying to leave it up to them. They want to help her."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "The Eternal Blossom could be used to make medicine to cure her, but we can't Synthesize it without a cauldron."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "That's fine! I'll brew it myself. I can't use alchemy, but I know how to prepare medicinal herbs."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "...I understand. Then we should move Monika to a safer place first."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Yeah."
        },
        {
            "type": 0x5,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "unknown2": 0x2,
            "msg_string": "Monika, are you feeling alright?"
        },
        {
            "type": 0x5,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "unknown2": 0x2,
            "msg_string": "Hey, put me down, Oskar!"
        },
        {
            "type": 0x5,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1f,
            "unknown2": 0x2,
            "msg_string": "Just be quiet, Monika. If you move around too much, the poison will spread faster."
        },
        {
            "type": 0x5,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "unknown2": 0x2,
            "msg_string": "There's no need to carry me."
        },
        {
            "type": 0x5,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "unknown2": 0x2,
            "msg_string": "You're better off relaxing."
        },
        {
            "type": 0x5,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "unknown2": 0x2,
            "msg_string": "That's... True, but..."
        },
        {
            "type": 0x5,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "unknown2": 0x2,
            "msg_string": "Just wait. I'll make that medicine for you in no time."
        },
        {
            "type": 0x5,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x24,
            "unknown2": 0x2,
            "msg_string": "You'll be fine! Just believe in us."
        },
        {
            "type": 0x5,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "unknown2": 0x2,
            "msg_string": "Us?"
        },
        {
            "type": 0x5,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x26,
            "unknown2": 0x2,
            "msg_string": "Yeah! Me, Sophie, Plachta, and of course the Eternal Blossom and the plants around here."
        }
    ]
}