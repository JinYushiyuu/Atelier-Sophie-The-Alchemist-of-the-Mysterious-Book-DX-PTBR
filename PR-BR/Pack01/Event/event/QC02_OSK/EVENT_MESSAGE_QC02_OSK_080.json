{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_080.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "*Sigh*... He did it again... I take my eyes off him for just a minute, and he always does this..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "He's really fast at running away for someone who's so heavy and out of shape."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "What's wrong?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Oskar was supposed to look after the store, but he left early and hasn't come back."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "What!? But he promised he'd start doing his work properly the other day."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "It seems like I'll have to give him a good scolding next time I see him..."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Sophie, Monika. Could I ask something of you two?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Do you want us to search for Oskar? Don't worry, Mrs. Marguerite, we'll find him."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Good at guessing, as I'd expect. *Sigh* If only my lazy son was this dependable..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sophie, you should help too. We need to set Oskar straight."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Y-yeah! This is for Oskar's own good."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I'm sorry I need to ask, but I'm counting on you."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Just leave it to us."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Sophie, I'll search the area south of the church. You search the north side."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Okay, I got it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Still, I wonder where Oskar went?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Probably somewhere with plants? He's always going to places like that in his spare time."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Yeah, he even went outside of town before... Wait, could he have gone outside again...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "That's possible. Let's search inside the town first. If we don't find him, we'll have to consider other options."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Yeah, that sounds good. I'll go now."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Yes, let's find him."
        }
    ]
}