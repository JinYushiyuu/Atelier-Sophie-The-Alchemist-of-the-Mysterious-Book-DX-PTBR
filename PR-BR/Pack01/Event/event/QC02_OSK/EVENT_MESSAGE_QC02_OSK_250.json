{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_250.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "I think I heard the voice from around here..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "But I don't see anything in particular."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "It's dangerous to stay here for too long. We should go back."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "Heeey, Eternal Blossom!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "Are you even listening!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Ah!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "You're the one who was calling to me. You're..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Stop."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Plachta...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "That plant isn't the Eternal Blossom. It's a different, poisonous plant."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "No way...! This has got to be the Eternal Blossom!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "You said you've never seen the Eternal Blossom yourself! How would you know!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I've never seen the Eternal Blossom before, but I have seen that plant."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "It has a terrible poison. Even a prick from its thorns will make you suffer from a high fever for three entire days."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "But this plant said it's the Eternal Blossom..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "In that case, the plant is lying."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "No way!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Humans lie all the time. Why would you assume that plants are incapable of lying?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x28,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "...We should go back for now. Come on."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Alright..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xe,
            "msg_id": 0x15,
            "msg_string": "Oskar..."
        }
    ]
}