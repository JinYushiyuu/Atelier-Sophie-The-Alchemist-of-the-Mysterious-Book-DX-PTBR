    "nb_messages": 0x13,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "So Sophie, did you find any information about the Eternal Blossom?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "I'm sorry, I couldn't find anything."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "I see..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "...Perhaps you could find it in the Forest of Fairies?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Huh?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "I remembered that there's a place called the Forest of Fairies to the far north."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Now that you mention it..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "It was inhabited by monsters, so most of the natural environment was left untouched."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "It's possible that it still remains that way now..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "That could mean the Eternal Blossom could grow there!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "I can't just sit around! Sophie, let's try going to the Forest of Fairies!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Huh!? But monsters live there..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "It's fine! I'll do something about it!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "And I'm sure the Eternal Blossom could be used as an alchemy material."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yes. I recall that it's an excellent ingredient for medicine."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "See! C'mon, let's try going."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "*Sigh*... Fine..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Alright, thanks!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "I wonder if we'll be okay..."
        }
    ]
}