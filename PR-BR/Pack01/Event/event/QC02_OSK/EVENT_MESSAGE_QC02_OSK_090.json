        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x35,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "He almost looks like a different person when he's skinny."
