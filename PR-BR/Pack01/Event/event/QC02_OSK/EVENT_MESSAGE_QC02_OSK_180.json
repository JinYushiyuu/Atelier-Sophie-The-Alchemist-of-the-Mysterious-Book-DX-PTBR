{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_180.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "This is a pretty place."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "The source of the river is near here."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "The water in Kirchen Bell flows from here, but it's much clearer here."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I came from a place near the sea, so I know a lot about the ocean, but vast lakes are beautiful too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I've never even seen the ocean."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x6a,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Haha, it doesn't look too much different from this. The main difference is whether you see mountains or islands."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Although, the scent of the wind is far different."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Huh, I'd like to go sometime."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "I would too! I'd also like to visit the Church's head cathedral."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yes, you can come visit anytime. I'll guide you around when you do."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Okay!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "...Huh? By the way, where's Oskar?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Heeey! Everyone, come over here!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "You're hopeless... Why don't you stick closer to the group?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "That's not important right now, look at this."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "What about this plant?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "What do you mean, what about it... This is the plant we came here for!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "It's a rare type that only grows in the mountains near clean water."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Is it really that rare? I would have never even known..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Same here... It looks like an ordinary plant without any special features."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "It can be used as an ingredient to make rare medicines, among many other uses."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "This would probably be perfect for alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Yeah, thanks Oskar."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now gather \"<CLGR>Crimson Herb<CLNR>\"."
        }
    ]
}