{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC02_OSK_240.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "This is the Forest of Fairies... The Eternal Blossom should be here somewhere..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "But how would we find it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Huh?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "The Eternal Blossom can't bloom if it's exposed to sunlight, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Do you even know what it looks like when it blooms?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Uh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "What!? You don't even know!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "I-I can't help that. The book only showed it in its closed state."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Oh, right! Plachta, do you know anything?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "I'm sorry. I never gathered it myself, and I've only seen it when the bud is closed."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "No way..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Heeey! Eternal Blossom! Could you answer me!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "There's no way a plant could answer your call..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "...Wait!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "W-what is it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "I can hear a voice..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "A voice?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I'm sure this is the Eternal Blossom's voice! Let's go!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "Hey, wait Oskar!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "We can't help it... We should follow him."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Y-yeah!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "..."
        }
    ]
}