    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x17b9,
            "msg_string": "Good evening, Mr. Horst."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1dbb,
            "msg_string": "Welcome, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x17ba,
            "msg_string": "Well, if it isn't Sophie. You shouldn't be out so late at night."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x17bb,
            "msg_string": "Oh, Harol... Eww, you stink like alcohol. You're drunk, aren't you?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x17bc,
            "msg_string": "Hahaha, so you can tell? That's right I'm drunk, totally drunk!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x17bd,
            "msg_string": "Sheesh... You're drinking too much. You're going to bother other people."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x17be,
            "msg_string": "Oh come on, give me a break Sophie. I used to always look after you."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x17bf,
            "msg_string": "You'd always call out like \"Haroool\" and follow close behind me... I still remember that."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x17c0,
            "msg_string": "Hey, that was a long time ago! Exactly how much have you had to drink...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1a,
            "expr_id": 0x2,
            "msg_id": 0x17c1,
            "msg_string": "Hahahaha! It's all good. I'm free to drink however much I want... *hic*"
        },
        {
            "type": 0x5,
            "voice_id": 0xe9,
            "name_id": 0x17,
            "expr_id": 0xffffffff,
            "msg_id": 0x17c2,
            "unknown2": 0x2,
            "msg_string": "Hey, look over there. That's Harol, the clockmaker."
        },
        {
            "type": 0x5,
            "voice_id": 0xfd,
            "name_id": 0x18,
            "expr_id": 0xffffffff,
            "msg_id": 0x17c3,
            "unknown2": 0x2,
            "msg_string": "He's always loitering around town, and never doing his job."
        },
        {
            "type": 0x5,
            "voice_id": 0xe9,
            "name_id": 0x17,
            "expr_id": 0xffffffff,
            "msg_id": 0x17c4,
            "unknown2": 0x2,
            "msg_string": "That's right. I thought he was just lazy, but apparently he's not very good at fixing clocks."
        },
        {
            "type": 0x5,
            "voice_id": 0xfd,
            "name_id": 0x18,
            "expr_id": 0xffffffff,
            "msg_id": 0x17c5,
            "unknown2": 0x2,
            "msg_string": "Huh... His father was a genius clockmaker, why'd his son turn out so pathetic?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x17c6,
            "msg_string": "...Damn it. Everyone's always comparing me to my dad..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x17c7,
            "msg_string": "Um, Harol. You shouldn't pay any attention to them..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x17c8,
            "msg_string": "I know my skills are nothing compared to him, but... I... Damn you all!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x17c9,
            "msg_string": "Harol..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0xffffffff,
            "msg_id": 0x17ca,
            "msg_string": "(He seems really concerned...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x17cb,
            "msg_string": "(Maybe I shouldn't have been so hard on him...)"
        }
    ]
}