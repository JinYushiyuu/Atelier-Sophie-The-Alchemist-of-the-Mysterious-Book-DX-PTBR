{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_HAR_210.ebm",
    "nb_messages": 0x1e,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Sophie, perfect timing. I just finished repairing that clock."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Wait, really!? Let me see!"
        },
        {
            "type": 0x5,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x2,
            "msg_string": "Here, this is it."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x2,
            "msg_string": "Wow, that's amazing! It's working just fine."
        },
        {
            "type": 0x5,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x2,
            "msg_string": "...Well obviously. I just repaired it, after all."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x2,
            "msg_string": "Ahaha, right. Sorry."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x2,
            "msg_string": "But I'm surprised you can repair such a small clock. The parts inside are really tiny, aren't they?"
        },
        {
            "type": 0x5,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x2,
            "msg_string": "Yeah, they are. When I first looked inside of a clock, I didn't think I could handle it."
        },
        {
            "type": 0x5,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x2,
            "msg_string": "But... After working with them over and over again, I gradually got the hang of it."
        },
        {
            "type": 0x5,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x2,
            "msg_string": "Experience really is important."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x2,
            "msg_string": "Huh... I see..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I'm glad I was able to fix it. To be honest, it would have been impossible for me just a little while back."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "A little while back... You mean when you were slacking off on your job?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "...Yeah. I was really discouraged back then."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Discouraged...? What do you mean?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "I was sick of being the son of a genius clockmaker."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "No matter how much I tried, I was always compared to my dad, and always treated like I didn't have any skills."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "I thought that it didn't matter how hard I worked anymore, and just tried to escape from it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "I see..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Yeah, but you gave me a chance, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Huh? I did? I don't think I did anything?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "No, you did. Back when I made Plachta's wind up springs... You told me that I was the only person you could rely on."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Ah... That's right. Back then, you really were the only person I could ask..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I was happy about that. Nobody had ever relied on me before in my life."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "I thought that if there was even just one person who relied on me, it was worth working."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Harol... So that's why you suddenly got serious about working as a clockmaker..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "...Yeah. I wanted to brush up my skills, so I wouldn't have trouble if you came to me again."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "I'm not my dad. I'll improve my clock making skills in my own ways."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "...Yeah! I'm sure you could become an amazing clockmaker too!"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x1d,
            "msg_string": "Heh, I guess so. I'll try my best."
        }
    ]
}