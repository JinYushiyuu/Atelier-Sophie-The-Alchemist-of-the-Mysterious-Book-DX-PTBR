{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_HAR_140.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Harol, what are you looking at?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah... I took apart one of my dad's clocks to look inside."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Your dad's clock?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "That's right... I hate to admit it, but my dad was really amazing. The design and techniques are all first class."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Huh... People always call your dad a genius clockmaker, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "...Yeah. I heard that when he was still your age, he had already made a name for himself."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "What!? Really? That's hard to believe..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I've heard talk that he was making clocks when he was just a kid."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "No wonder he's always called a natural born genius clockmaker."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "When he was a kid!? T-that must be an exaggeration..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Well, I don't know how much of it is true, since my dad won't talk about the past..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "But seeing how advanced his techniques are in this, I'd bet it's all true..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I heard that your dad was an amazing man, but I didn't realize he was THAT amazing..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Yeah. My dad really is an amazing man."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "He's so amazing that he completely overshadows me..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "..."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Harol learned the skill \"<CLGR>Precision<CLNR>\"."
        }
    ]
