        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "N-nothing. Never mind. More importantly, I need to give you your payment."
