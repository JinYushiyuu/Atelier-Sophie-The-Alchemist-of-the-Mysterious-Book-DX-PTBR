            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh? Let me see."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hmm... I said I don't care about the quality, but let's see just how much of this is usable..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "How is it...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "...Sophie, did you really gather all of this?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Huh? Yeah, I did..."
