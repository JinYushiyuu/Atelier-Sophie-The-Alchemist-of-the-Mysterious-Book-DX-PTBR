        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "No, it's the opposite. This is all far better quality stuff than what I get in stores."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "...I'm impressed you managed to gather something so good."
