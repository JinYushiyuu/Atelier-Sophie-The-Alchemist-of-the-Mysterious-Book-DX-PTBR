        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Thank you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "...I'm the one who asked you to work."
