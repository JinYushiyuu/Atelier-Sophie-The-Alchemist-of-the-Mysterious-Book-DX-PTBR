{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_HAR_100.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Harol!"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "...What is it, Sophie? You're louder than usual today."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Um, I wanted to properly thank you for helping with Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Thank you very much for making Plachta's wind up springs."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Oh, that..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "I was kind of in doubt, and didn't think you'd actually manage to pull it off..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I was pretty shocked when you brought Plachta over."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Yeah, but I was able to make Plachta into a doll because you made the springs."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I'm really glad that I asked you to do it."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "...I see. You know, Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yes?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "I feel weird about this myself, but... When I was making those springs, I was enjoying it a little."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Huh... Really? But you seemed to dislike the idea so much..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Yeah. To be honest, I had a lot of trouble making that. I was really annoyed..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "But there was still a part of me that was enjoying it."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "...I wonder why? I know I hate clock making..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Hehe, maybe you actually don't dislike clock making as much as you think?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "Don't say stupid things. I absolutely hate clock making."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Ahaha, I guess you won't admit it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "But really, thank you Harol."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "...Sure."
        }
    ]
}