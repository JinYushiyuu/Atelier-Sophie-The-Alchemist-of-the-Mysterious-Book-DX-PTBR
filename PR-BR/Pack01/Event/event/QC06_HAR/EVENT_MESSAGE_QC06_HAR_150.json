{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_HAR_150.ebm",
    "nb_messages": 0x12,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Harol, I'm here for a visit."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "...Hah."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Hey! Did you just look at me and laugh!? Why!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "Oh, sorry. I was just reminded about the past."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "The past...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Back when you were little, you'd always come over to play."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ah, yeah, that's right. Your dad and my grandma were good friends..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "While they talked together, you'd always play with me."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "...It was pretty rough babysitting you. You were always up to mischief."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "A-ahaha... I was just a little kid, you can't really blame me..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Still, you sure have grown up since then. You're even running that atelier by yourself."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I hear people talk about your atelier at times, and it's always good. Sounds like you've been working pretty hard lately."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Ehehe, really? I'm kind of happy about that..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "...I don't know if my opinion means much, but I think you're doing pretty well."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "So you should be more confident."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Harol... Yeah, I got it! Thanks!"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Still, I never thought little Sophie would grow up to be like this."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "I'm feeling old now..."
        }
    ]
}