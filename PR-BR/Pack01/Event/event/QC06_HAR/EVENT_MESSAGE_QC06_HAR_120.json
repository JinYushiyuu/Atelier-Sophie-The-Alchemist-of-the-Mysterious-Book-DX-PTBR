{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_HAR_120.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Elise, do you have any new interesting books?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Sophie. Welcome."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "...I never thought I'd meet you here, Sophie. I guess the world's ending tomorrow."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Grr, that's my line. Why are you here, Harol?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "I came to look at books to kill some time. I've finished my business, I'll leave now."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Oh, I see. Bye then."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yeah. Don't waste too much money."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "That was surprising. I didn't think I'd see Harol at the bookstore..."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hehe, actually, Harol's been coming here quite often recently to buy books."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Wait, really? That's unexpected."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "What kinds of books does he read? He said he was just killing time..."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "He mostly looks at books about clocks."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Books about clocks...? And you're sure you're talking about Harol?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yes, he reads many of them. He's bought quite a large number already."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(Harol's reading books about clocks... And a huge number of them...?)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "(He was repairing a clock the other day too... Seriously, what happened to him...)"
        }
    ]
}