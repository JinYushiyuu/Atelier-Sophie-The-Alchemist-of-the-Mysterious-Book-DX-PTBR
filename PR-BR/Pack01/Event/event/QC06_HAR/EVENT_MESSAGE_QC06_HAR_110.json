{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC06_HAR_110.ebm",
    "nb_messages": 0x13,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Harol..."
        },
        {
            "type": 0x5,
            "voice_id": 0xee,
            "name_id": 0x20,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x2,
            "msg_string": "Thank you, you really helped me."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "No problem... Come back anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "Huh, was that... A customer?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "...Did it look like we were just having tea and crumpets to you?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "No, it didn't... But I'm surprised. I didn't think I'd ever see you serving a customer..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "I work with customers all the time."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hmm... Were you selling guns again?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "No, this was for clock repairs. The spring had snapped, so I fixed it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Wait... You repaired a clock!? Did you hit your head? Or eat something bad?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "...You sure do say terrible things."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "This is a clock shop. There's nothing strange about repairing clocks here."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x27,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "B-but, you wouldn't even try to work on clocks, no matter what I said."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Why the sudden change of heart?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "No reason in particular... It was just a whim."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Huh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "(Harol repaired a clock? What could have possibly happened...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "msg_string": "(I mean, it's not anything weird, just like he said... But this is Harol we're talking about.)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "(Hmm... I'm curious now...)"
        }
    ]
}