{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_FRI_010.ebm",
    "nb_messages": 0x12,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "...I publicized the request for it, but it's so unsettling that nobody will accept it."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "I feel very sorry for asking, but could you go and investigate it?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "No way, I'm waaay too creeped out too. You can go yourself, Meister."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "No, I... Um... I have work to do."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "What are you two talking about?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ah, Sophie. You came at a good time. There's actually a request I have... Will you do it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "A request? Yes, of course! Just leave it to me!"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "...Oh boy, she accepted it. You didn't even want to know what kind of request it is?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Huh? Isn't it just gathering materials, or slaying monsters like usual?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "...This is probably way worse."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "...What?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I've received complaints that every night lately, there are strange voices coming from a cabin near town."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I'd like you to go and check the cause, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "It could be... No, it's definitely the work of ghosts."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "WHAAAAAT!? No! No, I don't want to go!"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Hahaha, but you've already accepted the request. It would be troubling if you didn't complete it."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "And now you know not to accept things without knowing what they are. Well, good luck out there."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "N-no way..."
        }
    ]
}