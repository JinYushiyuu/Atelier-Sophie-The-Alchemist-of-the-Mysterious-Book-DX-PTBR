{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_FRI_110.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Harol, I'm here for a visit..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Huh, Fritz? What are you doing in a place like this?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "\"A place like this\"? That's pretty rude."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "A-ahaha... Sorry..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Well you see, I was learning how to make wind up springs from Harol."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Huh? Wind up springs?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yes, after seeing Plachta, I want to make dolls that move as well."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Seeing how Harol was the one to make the springs, I came to ask him how he made them."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Fritz here is a natural. He already learned the basics."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Really? That's amazing!"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3f,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "No, Harol's just really good at teaching."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Not really... Well, anyway. Now you should be able to make simple springs yourself."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I see. Then I suppose I'll go home and give it a try."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "If there's something you can't figure out, come ask me again anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yeah, I'll do that. Thanks."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "*Sigh*... If only I was that fast at learning..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Huh, was Fritz really that good at making wind up springs?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yeah. He improved at a ridiculous speed. Who exactly is that guy..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "(Hmm, Harol's saying that much about him... He must have been really amazing...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "msg_string": "(Fritz is a really talented man...)"
        }
    ]
}