{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_FRI_050.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Yes?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Excuse me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Fritz!? Wait, I don't remember telling you where my atelier was."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I asked Horst about it. So you're an alchemist, Sophie?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Yes, but she's just a novice."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Hmm, a talking book? How unusual."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "You aren't surprised seeing Plachta...? Do you know a lot about alchemy?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "I don't know a lot, but I've traveled a lot. I've seen some strange things in my time, so I'm not easily surprised."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Huh, I see..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "By the way, Sophie. Seeing how you're an alchemist, I have a request. I'd like you to make something for me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Oh, okay. I don't mind. What is it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "It's string for use with dolls. I need special strings, but I can't find any in this town."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I'm a doll maker. I also put on puppet shows to make a living. Not having strings is a matter of life and death."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I see... I understand. Just leave it to me!"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Sorry about that. I know I'm asking a lot, but when you're finished, can you bring it to my house in Old Town?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Okay, I'll bring it to you."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Heh, thanks. I'll be going now."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "A puppet show, huh... I want to see Fritz's puppet show sometime."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "To do that, first you'll need to make the puppet strings properly."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x40,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Yeah! I'll do my best."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Received \"<CLGR>Puppeteer's Tools<CLNR>\"."
        }
    ]
}