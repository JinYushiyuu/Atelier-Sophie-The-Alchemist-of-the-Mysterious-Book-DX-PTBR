{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_FRI_180.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Plachta, are you here?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Fritz. It's unusual for you to have business with Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Heeey, Plachta. Fritz is calling for you."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "You have business with me?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, Plachta. I know this is sudden, but..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Let me see your body."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "...Sophie, could you lend me a high powered bomb? I need to turn this person here to ashes."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "...Okay, go right ahead Plachta. I didn't think Fritz was THAT kind of person..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Wait! This is a misunderstanding! I didn't mean it like that! I'm just here for maintenance on Plachta's body!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Huh? Maintenance...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yeah. It doesn't matter if we used special alchemy materials to emphasize durability, long use will cause wear."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "You may have transferred her soul inside, but as long as she's a doll, she needs regular maintenance."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "That's true... To be honest, my right arm has been feeling a little uncomfortable lately."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Wait, really? Plachta, you should have told me..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "I'm sorry. I didn't want to make you worry..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "...Now you realize how important maintenance is, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yes... I'm sorry for misunderstanding."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "...I don't mind. Anyway Plachta, can I give you a checkup now?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "I understand. Please do so."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "That should do it. How do you feel, Plachta?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "The discomfort has disappeared completely."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "The joint between the parts was slightly dislocated. I readjusted it."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Just tell me if you have any problems with other parts. I'll fix them anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I will. Thank you very much, Fritz."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "No problem. I'll be taking my leave now."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "...We did something bad to Fritz."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "...Yes, we did. He came here with good intentions, but we were rude to him."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "(But I didn't even realize that Plachta's body wasn't working right...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "(I should pay attention to Plachta more carefully from now on...)"
        }
    ]
}