{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_FRI_100.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Huh? That's... Leon, and Fritz?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2e,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "That's an unusual combination... I wonder what they're talking about..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Hm, that's surprising. I didn't think you were making your dolls' clothing yourself, too."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "I think it's best for the dolls I make to wear clothes I make as well."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "I see... I don't dislike an attitude like that."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "I heard you're a very skilled clothier. I thought you could give me some good advice about making clothes."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Let's see... I think the basic ideas behind human clothes and doll clothes are the same."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "You need to consider what clothes are most suited for the individual, not relying on superficial flair."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Hm, I see... So you need to think about what clothing would suit them best..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sorry, I know it sounds a bit abstract."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "No, that helps. Your main occupation is a clothier, and you're saying that. There must be truth to it."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Next time I make clothes for a doll, I'll keep what you said in mind."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Yeah, you should do that."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I will. Today's conversation was a valuable reference, thank you. I'll see you again."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hehe, come back anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "(He was making clothes for his dolls too...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "(Fritz is pretty amazing to be able to do something like that...)"
        }
    ]
}