{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_FRI_240.ebm",
    "nb_messages": 0x12,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Oh, Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hello, Fritz. Are you thinking about something?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Yeah, I was thinking about going to the next town."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "What!? You're going to leave this town already?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Don't jump so far ahead. I'm talking about the future. But I can't stay here forever."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Ah, I see. That's a relief... But why are you thinking about it now?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I'm actually thinking about searching for my daughter."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Oh really? But you said before that you didn't need to do that..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Thanks to you, I was able to create a magnificent doll. I wanted to show it off to her. Heh heh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Oh, I get it... I understand now..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "But you're going to be leaving someday. I'll feel a little sad..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Haha, meetings and farewells are all a part of life. There's nothing to be sad about."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Also, I promised you that I would show you the greatest puppet show in the world. We'll meet again."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Fritz... Yeah, that's right!"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I'd need to make a lot of preparations to set out."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Until then, I intend to continue putting on puppet shows here. I'll be working with you for a while longer."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yes, I look forward to it!"
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Fritz learned the skill \"<CLGR>Master Swordsman<CLNR>\"."
        }
    ]
}