{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC04_FRI_120.ebm",
    "nb_messages": 0x13,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Fritz, you really do like dolls, don't you?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "What's wrong, Sophie? Why are you asking the obvious all of a sudden?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Because you're always studying really passionately about anything related to dolls."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "You learned about clothes, and wind up springs. You seem to love dolls from the bottom of your heart."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "I see, so that's why you asked... As you said, I like dolls. I love them."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "I love them so much that I'd never stop working on them, and I'll do anything for them."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "I've devoted my life to dolls."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Devoted your life, huh... It's amazing that you can declare something like that."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Did you like dolls when you were kid?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "No, I only started liking dolls after I became an adult."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Huh, that's a little unexpected..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "While I was still a mercenary traveling the world, I had an opportunity to watch a puppet show..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "That puppet show is what caused me to be totally captivated by dolls."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "...So much so that I quit my mercenary work, and became a doll maker."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "I see..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "I would have liked to see that puppet show..."
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Oh really? I can't say it'll be exactly the same, but I can put on a similar show for you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Wait, really!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Yeah. Alright then, in that case..."
        }
    ]
}