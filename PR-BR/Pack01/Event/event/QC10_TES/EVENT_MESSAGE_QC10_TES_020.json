{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC10_TES_020.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, Tess. Hello."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hey, Sophie. You look cheerful today, as usual."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yeah. By the way, what are you doing here?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm actually on break right now. We finally had a lull in customers."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I see... It must be hard work."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Oh no, it's all just part of my job... By the way, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Have you ever gone into that shop?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "That one? No, I haven't..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "I see... They have a reputation for being really good, but it's kind of awkward to go in there alone."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "I would invite my friends, but we're all really busy and can't get our schedules to match..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "I see... Oh, I have a good idea!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Tess, would you like to go together sometime?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Huh, is it okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Yeah. I'm interested to see it, and it would be fun going somewhere with you."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x28,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I'm happy you feel that way. Well then, let's try going sometime."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Okay!"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yeah, I look forward to this. Also..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Also...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Good food makes a good reference for our shop. There's really no downsides to trying it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Huh... You're even thinking about that? You really are serious about work."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3f,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "No, I'm not that serious... But since I'm working there, I want the cafe to do well."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "...Uh oh, it's already this late. I need to get back to the shop soon."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Okay. Do your best at work."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Yeah, thanks. Alright, time to get through another day."
        }
    ]
}