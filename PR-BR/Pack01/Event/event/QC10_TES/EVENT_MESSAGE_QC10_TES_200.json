{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC10_TES_200.ebm",
    "nb_messages": 0x17,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x0,
            "msg_string": "Finally... You've finally obtained it! The date ticket with me!"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "You said you didn't care for it before... You're such a tease, Sophie!"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "But I knew all along. I could see that deep inside those eyes of yours, there was a burning desire... For me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Anyway, Tess, I'll see you later. Bye."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Aah, I'm sorry! Wait up! I went too far! I'll apologize!"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "...You should realize that this is just my way of hiding my embarrassment..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Wait, it is?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "It's only natural. I'm not someone who just goes out on dates on a whim..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "But you did your best to save up those vouchers... And I feel at ease knowing it's with you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Tess..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Anyway... Let's go on our date now!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "What!? Right now!?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Of course. The date ticket's only good for today."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "I-I see... Oh well..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Anyway, Meister, we're going now. Take care of the shop until I'm back."
        },
        {
            "type": 0x5,
            "voice_id": 0xe9,
            "name_id": 0x17,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x2,
            "msg_string": "Hey, wait... Is Sophie taking Tess out on a date!?"
        },
        {
            "type": 0x5,
            "voice_id": 0xfd,
            "name_id": 0x18,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x2,
            "msg_string": "Damn it. I didn't think Sophie would beat us to it..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Let's just ignore them. Anyway, shall we get going?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Okay."
        },
        {
            "type": 0x5,
            "voice_id": 0xe9,
            "name_id": 0x17,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x2,
            "msg_string": "Aaah! Horst! A drink! Give me a drink!"
        },
        {
            "type": 0x5,
            "voice_id": 0xfd,
            "name_id": 0x18,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x2,
            "msg_string": "Me too! I need to drink to forget! Let's just get drunk!"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Oh my... I need to attend to all these customers myself...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Well, I suppose I can look the other way for one day."
        }
    ]
}