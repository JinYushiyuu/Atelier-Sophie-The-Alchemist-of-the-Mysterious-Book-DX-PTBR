    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Ah, Sophie... Welcome..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Huh? ...Tess, you don't seem very lively?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Yeah, kind of..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "I'd be willing to listen, if you want to talk."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Really? ...Well you see, one of my little brothers caught a cold."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "I was taking care of him, and didn't sleep, so I'm pretty tired..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "T-that doesn't sound good. Should I make some medicine?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "No, we have medicine already. Although he doesn't want to take it because it's bitter..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "I see... That reminds me, I didn't like medicine when I was little, too..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "I understand how you feel. I don't exactly like it either."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "But he seems to be in pain... I want to help him..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Hmm... What could we do..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "I'll try thinking about it a little more. I woke up after talking to you... Thanks, Sophie."
        }
    ]
}