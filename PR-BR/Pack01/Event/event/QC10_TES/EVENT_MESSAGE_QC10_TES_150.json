            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I thought it would be great if I could come up with some dishes with ingredients that anyone could eat."
