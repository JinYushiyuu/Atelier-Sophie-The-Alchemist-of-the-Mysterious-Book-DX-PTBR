            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I see... Food that anyone can eat, huh... That sounds wonderful!"
