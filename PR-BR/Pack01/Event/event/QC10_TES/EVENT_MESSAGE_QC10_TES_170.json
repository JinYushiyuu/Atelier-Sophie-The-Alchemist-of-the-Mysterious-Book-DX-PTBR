{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC10_TES_170.ebm",
    "nb_messages": 0x19,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x0,
            "msg_string": "Hey, Meister. That's really wasteful."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Really...? I don't think this can be used any further..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "No, it's important to economize. Every little thing counts."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "There's truth to that, but..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hello."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ah, welcome."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Welcome, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "What were you talking about?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "It's about ingredients. There's still some usable stuff left, it's wasteful to throw it away."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "So you're trying to economize..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yeah, that's right."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "For example, putting food aside, you can also reuse the cloths for drying glasses as dust cloths..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "There's plenty of ways to economize, Meister."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "...You might be right about that. Perhaps I should try to economize more."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "That's right! Oh, by the way, I was thinking about one really good way for a while!"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Hm, what's that...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "I want to know too!"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Heh heh heh. Just try not to be too surprised, okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "You can dry out used tea leaves, and sell them for cheap! It's good for the environment, too... What do you think!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "T-that's a little..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Yes... That's one thing my pride would never allow..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "Wait, it's no good...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Yes, that proposal is rejected."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Whaaat... But I thought it was a good idea..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Ahaha..."
        }
    ]
}