{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC10_TES_120.ebm",
    "nb_messages": 0x13,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hey, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hello, Tess. How's your little brother's cold?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "He's perfectly fine now. He's running around like usual."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "That's good."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "But still..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "??"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "I was thinking about how I didn't want to see them in pain again, like the other day."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "If they take medicine, they'll get better, but they don't want to. It makes the suffering last longer, I feel bad."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "You said they don't want to take it because it's bitter, right...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "...Oh, I know."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Huh? What?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "If they don't like bitter medicine... I just have to make sweet medicine."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Sweet... Medicine?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yeah. For example... If it's sweet like syrup, they'd probably be more than happy to drink it."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "...Sophie, that's an amazing idea! You might even be a genius!"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1a,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "I'm sure my little brothers would drink that. Not just my brothers, but all the kids in town!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Really...? Well, I guess I should try making it."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yeah, give it a try! I'll be cheering for you, Sophie!"
        }
    ]
}