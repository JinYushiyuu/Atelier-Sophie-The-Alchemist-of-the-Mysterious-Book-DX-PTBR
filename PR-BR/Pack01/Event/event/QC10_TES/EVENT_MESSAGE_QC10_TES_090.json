{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC10_TES_090.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "I'm so sorry, Sophie!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Tess!? What's wrong!?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "This is my life's wish! Sophie, you need to help me!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "S-sure... What did you do this time...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "I sprinkled the poison on the yard. All the weeds stopped growing, but the flowers stopped growing too..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Oh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x51,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "(Looks like my bad feeling was on the mark...)"
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "I didn't predict something like this. It would have been perfect if just the weeds had died..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "At this rate, my yard will be a barren wasteland, where not even a single blade of grass can grow."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x51,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "*Sigh*..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "And that's where you come in! I want you to make me some fertilizer, so the flowers will grow again."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Also, it needs to work instantly, and be super effective!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Hmm, fertilizer... I can make it, but..."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Is it really hard to make?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "No, it shouldn't be too hard. It's not hard, but..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "If you use fertilizer, I'm sure the weeds will start growing again too."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "I'll be sure to pull out the weeds myself..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Ahaha, I see. In that case, I'll make it."
        },
        {
            "type": 0x2,
            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Okay. I'm really sorry for asking... I'm counting on you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Yeah, just leave it to me."
        }
    ]
}