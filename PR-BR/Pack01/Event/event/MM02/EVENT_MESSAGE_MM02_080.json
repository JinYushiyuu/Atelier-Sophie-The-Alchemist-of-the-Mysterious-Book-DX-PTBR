{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM02_080.ebm",
    "nb_messages": 0x28,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hm, who could that be... Yeees, it's open."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x25,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Excuse me. Is this the alchemist's atelier?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yes, that's right... Oh wait! You're! You're the guy who saved me...!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x25,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, you're the girl from before. What a coincidence."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "That reminds me, I hadn't told you my name. I am Julio, a knight of Adalett."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Sir Julio... Um, my name's Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Sophie? That's a fine name."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Ehehe, thank you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "But you said you came from Adalett? That's a neighboring country, it must have been a hard journey."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "It was no trouble at all."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I'm actually conducting an investigation on alchemy, visiting alchemists in various regions."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x6c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I heard that there was an elderly alchemist living in this town, and I came to speak with them."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Oh... I think you're referring to my grandma."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Ah, I see. Is your grandmother home now?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "I'm very sorry, Sir Julio. My grandma actually already..."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Oh, I didn't know... I'm quite sorry. I'm sure my asking was unpleasant."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "No, it's okay. I'm sorry you came all this way for nothing..."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "No, that's nothing for you to apologize for. But this is quite a problem..."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "It seemed the alchemy your grandmother used was closest to that which I require."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Alchemy using certain materials as a base to create completely different things. A shame..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "Sounds like a suitable candidate is right in front of you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Hey, Plachta! You're going to shock him, don't just start talking out of nowhere...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Haha, a talking book? I'd expect no less from the atelier of an alchemist."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Um, you're not surprised...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "I'm surprised, but... I've seen quite a lot of the mysterious power of alchemy up until now."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "But a suitable candidate...? Sophie, are you an alchemist as well?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Oh, yes. But I'm still inexperienced, so I don't know if I could help you..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "It's true that Sophie's skills are still developing. However, I believe her potential is great."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "If Sophie keeps improving, she will be far more suitable than traveling around speaking to random alchemists."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Perhaps there was some divine guidance in our meeting. This may be worth wagering on..."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x1e,
            "msg_string": "Sophie. I'd like to wager on your potential, and your development into a grand alchemist."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Until then, I'd like to assist you. Alchemists need to travel to dangerous areas to gather materials, correct?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x6a,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Combat is about the only thing I'm capable of, but I'd like to guard you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Yes, of course! That would help me so much!"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "That's good. In that case, I'll be staying a while in this town. Call upon me when I'm needed."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "...A grand alchemist, huh."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x24,
            "msg_string": "I wonder if I can become an alchemist who's capable of helping him..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "msg_string": "I told you, you have the potential, Sophie. It all comes down to your effort."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x26,
            "msg_string": "Okay! Now I need to work hard for Julio too!"
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "\"<CLGR>Julio<CLNR>\" joined your party."
        }
    ]
}