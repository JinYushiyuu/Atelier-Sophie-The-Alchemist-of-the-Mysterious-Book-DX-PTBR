            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "So where's this monster you were talking about?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Uh... Oh, over there."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "Wait... Is that... The monster?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "Yeah, that's the one."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Wait, Oskar! You never said it looked THAT strong!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "I did! I clearly told you it was a \"terrible\" monster!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1f,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "I know you said that! But you didn't say it was THAT terrible!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Stop, both of you! Be quiet...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "It noticed us!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "W-what should we do...!"
        },
        {
            "type": 0x5,
            "voice_id": 0xffffffff,
            "name_id": 0x14,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
