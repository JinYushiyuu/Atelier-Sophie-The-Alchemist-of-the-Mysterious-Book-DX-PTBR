        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "A-aaaah!"
        },
        {
            "type": 0x5,
            "voice_id": 0x4,
            "name_id": 0x25,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x2,
            "msg_string": "Haaaaaah!"
        },
        {
            "type": 0x5,
            "voice_id": 0xffffffff,
            "name_id": 0x14,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x2,
            "msg_string": "GUGAHH...!"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x2,
            "msg_string": "Wha...?"
        },
        {
            "type": 0x5,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0xffffffff,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "unknown2": 0x2,
            "msg_string": "The monster..."
