{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM02_040.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Sophie, are you home?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "We've come for a visit."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, both of you, perfect timing! I actually have something amazing to tell you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Something amazing? Like what?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Heh heh heh... I'm sure you'll be surprised."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "C'mon, what is it? Stop putting on airs, and just tell us."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Okay, okay. You see, there's a story about this really amazing cauldron..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "An amazing cauldron? ...What kind of cauldron?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Well you see, it's called the \"Cauldron of Knowledge\". If you obtain it, it lets you use really amazing alchemy!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Huh, amazing alchemy? Like what?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Um... I don't know."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Oh... So where is this \"Cauldron of Knowledge\" anyway?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Well... I don't know that either."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Sounds like you don't know anything about it. Who'd you hear this story from?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "From Plachta... But it seems like she's forgotten all the details..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Then it doesn't sound like something to worry about... You don't even know if it really exists."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "But it does sound like something out of a dream. I can understand why Sophie would want it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yeah. I really want to find it, but..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "I suppose so. If there's anything I can help with, just tell me. I'll do what I can."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Me too! ...In exchange though, if you find it, I want to use it a little."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "That's fine! Thanks, you two!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I'll be going now."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "I should leave too. See you later, Sophie!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Yeah, see you later!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x18,
            "msg_string": "If I had that Cauldron, I'd be able to use alchemy like grandma did."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x19,
            "msg_string": "I'll definitely find it...!"
        }
    ]
}