{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM02_050.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x49,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Okay, it's done!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4f,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Now to write the recipe."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "How's that, Plachta?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "...Let's see. It seems a small part of my memories have come back."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Really? What did you remember this time?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "I know I'm not a normal book. I was created using alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "That's why you can fly and talk."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "Also... I remembered my purpose."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Your purpose...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "Yes. My purpose is to store knowledge of alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "As a reference book, I am to change hands between alchemists, accumulating their wisdom. That is my purpose."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "It seems that I have been possessed by many alchemists so far for that goal."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "And that's why you ended up with my grandma too?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "Yes. Although I was set aside by your grandmother as soon as she obtained me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "A-ahaha... I'm sorry about that, Plachta..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "It's fine. You're writing knowledge of alchemy into me in her place now."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "Thanks to you, I've been able to fulfill my purpose and regain my lost memories at the same time."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "msg_string": "If possible, I would be grateful if you continued to write new knowledge into me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Of course I will, Plachta. Alright, I'm going to write all kinds of things into you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Things like recipes for delicious sweets, and how to make cute accessories... All kinds of stuff!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "...Sophie. Please refrain from writing things other than information about alchemy."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Plachta told you about a new gathering field that she remembered."
        }
    ]
}