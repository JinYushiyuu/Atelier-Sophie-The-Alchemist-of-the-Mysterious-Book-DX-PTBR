{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM02_200.ebm",
    "nb_messages": 0x1f,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "Sophie, what are you reading?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Plachta. I was just looking through my grandma's diary. I found it on the bookshelf earlier."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Grandma was the type to record every detail, so there are entries about going places, and making sweets too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "It's all really nostalgic... But it also makes me really sad."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "It's been a long time now since grandma passed away."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "I lost my mom and dad when I was really young. Grandma was the one who took care of me for all that time."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "But now grandma's gone too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "When I got back home from grandma's funeral, this atelier suddenly felt like it was really big. Too big."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "I was sad, and scared, and lonely at the same time. I felt like I was all alone in the world."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "msg_string": "..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "A-ahaha. Sorry about the gloomy story."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oh, I'm fine now, just so you know. Monika and Oskar come to visit really often too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Still, I did feel a little lonely at night... Although that's not the case anymore lately."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "Why?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Ehehe... It's because you're here, Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "You're here, even late at night, so I'm never alone."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "That's why lately, I don't feel lonely, even at night. It's actually fun now that you're here."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "...I'm really thankful, Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "msg_string": "...Hehe. So you're the lonely type, Sophie?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x14,
            "msg_string": "Wha!? N-no! I'm not the lonely type at all!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "...Sophie, don't worry. I won't leave you alone and go anywhere."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Plachta...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "I would feel too sorry leaving such a lonely person all by themselves."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x18,
            "msg_string": "Hey! You called me a lonely person again! I'm telling you, I'm not!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "msg_string": "How are you not? I don't understand your reasoning."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1f,
            "expr_id": 0x3,
            "msg_id": 0x1a,
            "msg_string": "Grr! If you don't behave, even I can get mad!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "Hehehe..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x1c,
            "msg_string": "Ahaha..."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0x29,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1d,
            "msg_string": "Ahahahaha..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "msg_string": "Ahahahaha..."
        }
    ]
}