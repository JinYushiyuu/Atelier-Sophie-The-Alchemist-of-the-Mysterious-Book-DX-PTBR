{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM02_030.ebm",
    "nb_messages": 0x26,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hey Plachta. We should go gathering together."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "Sophie, I told you before, but I wouldn't be of any use in combat."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "That's not why I'm asking... I want you to tell me which materials are good and which ones are bad, stuff like that."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "I see, I understand. In that case, I'll accompany you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x4,
            "msg_string": "Yay! Then let's get going!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "By the way, this is the first time we're going outside together, isn't it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Now that you mention it, yes it is. It's quite refreshing."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "It's fun walking around with you, Plachta. Well, you're flying, not walking..."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "...Hey you, can we ask you a question?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Huh? M-me?"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0x25,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yes. A question for you. What exactly is that flying book?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "Huh!? U-um..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x27,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "msg_string": "(W-what should I say... I wouldn't want to create a spectacle. It's better if less people know about this...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Um, well you see. I'm an alchemist. I made this book myself."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I figured it would be funny if a book flew around. Y-you know, weird things are amusing, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "An alchemist..."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0x25,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Hm... So you're an alchemist. What a coincidence."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Huh...? What's the coincidence?"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0x25,
            "extra_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "We're actually researching alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Wait, really? You're still so young... That's really amazing."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0x25,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "We're researching it, but we don't have the natural talent, so we can't do anything with it."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0x25,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Yeah, but it's still pretty fun to research things, even if you can't do it yourself."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0x25,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Anyway, Miss Alchemist. Can we ask your name?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Sure. I'm Sophie. Who are you?"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "I'm Meklet."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "I'm Atomina."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "As we said before, we're researching alchemy. We may come to you to ask things about it."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "We'll see you then, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Oh, sure. Come ask me anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "We should get going, Atomina."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Yes. See you later, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "There was something about those two... I got this really strange feeling..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Oh well. Sorry for making you wait, Plachta. Let's go gathering now."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x21,
            "msg_string": "...I'm going home."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x22,
            "msg_string": "Huh?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "msg_string": "This \"weird\" flying book is going back to the atelier. Go gathering by yourself. Bye."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x24,
            "msg_string": "Wait, is this about what I said to them? I was just kidding! Wait up, Plachta!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x25,
            "msg_string": "Come back, Plachta!!"
        }
    ]
}