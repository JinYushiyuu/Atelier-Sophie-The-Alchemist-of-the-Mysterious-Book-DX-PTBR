    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hmm. I somehow managed to sort out the issues with Plachta and Luard, and I've got better at alchemy..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "But it's still not enough. I'm still nowhere near the level of Grandma, or Plachta..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Hmm... What explains the gap between them and me? I feel like it's more than just experience..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Grandma did tell me once, \"Sometimes you need to doubt conventional wisdom.\""
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "That might apply to alchemy, too. Maybe just following standard theory isn't enough..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Okay. Let's think. Doubt conventional wisdom... Make something that seems impossible..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Excuse me, Sophie... The duplicated items you asked for are ready..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0xf,
            "msg_id": 0x7,
            "msg_string": "...That's it! Duplication!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "Huh?! U-Um... What about duplication...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Ah, s-sorry, Cory! Don't mind me. I was thinking of something else."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "A-Ah... I'll leave what you wanted here, and I'll just leave you be..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Okay, thanks! See you later!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Duplication...! If I could make something to duplicate other items, it would be so useful!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Cory's duplication technique is a type of alchemy. I need to think up a new, radical recipe!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hmm. Maybe I should talk to Cory first to get an idea... Okay, here I go!"
        }
    ]
}