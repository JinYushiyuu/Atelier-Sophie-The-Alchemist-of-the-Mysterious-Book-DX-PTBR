{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_XX01_080.ebm",
    "nb_messages": 0x25,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Now then. The herb you wanted should be somewhere around here!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "...Hm?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "But you'll want the very best available. We need to find the freshest..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Hmm..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "...Um, Cory? What's with all the pensive grunting?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "You've been looking at me the whole time. Have I been doing something odd?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "No... But there is something I was wondering about..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Sophie... Your clothes are different than normal, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "...You've only just noticed?! I've been wearing Grandma's clothes this whole time!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Oh, really...? I'm sorry... I never noticed..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Hahaha... It doesn't really matter, of course... But still..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Um, Sophie... I do like those new clothes you're wearing... But it's missing..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "What do you mean, it's missing?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "The cup you used to have attached to your rucksack. I used to like the way it swayed..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ah, the cup. Well, it may not be attached to my rucksack, but I've still got it!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Hehe. I really need that when I go gathering ingredients. Plus I got it from Grandma!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "...From your grandmother?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yup! It was made just for me, using alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "When I was a kid, I used to just scoop water up from ponds with my hands and drink it..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Ah... I had no idea you were such a wildling..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I-I was just a small child! But Grandma didn't like it..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "So she used alchemy to make me a cup that would purify any water!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Huh... So there's more to that cup than meets the eye..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Yup. She could have just made me a normal cup, but she was thinking of my future."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "She told me to take the cup with me on all my travels in the future!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "Hehe, is that right...? She must've been very proud of you, then."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "Huh...? Grandma... Proud of me?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "Yes. I mean, you've been to so many different places..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Even just leaving town is like going on a journey... You're a legendary traveler."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "...! I guess you're right..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x1e,
            "msg_string": "Haha. Come to think of it, this cup has helped me a lot. I owe Grandma a debt of gratitude."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "I think so, too... But I know she'd be proud of you."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "Hehe, I hope so. Come on then, let's get gathering!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Just you wait, Cory! I'll gather these herbs in no time flat!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "I'm counting on... Ah, Sophie, don't run off on your own...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Sophie...! You may be a legendary traveler, but you mustn't go off on your own...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Wait...! Sophie...!"
        }
    ]
}