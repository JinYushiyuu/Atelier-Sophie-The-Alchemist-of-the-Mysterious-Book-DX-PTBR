{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_XX01_210.ebm",
    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Here I am, Grandma."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Um, I've decided to leave Kirchen Bell, and go on a journey."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "I never imagined that you were a Certified Alchemist. Haha, what a surprise that was."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "But no matter how great you were, I will continue my quest to try and match you, Grandma."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "...No, I won't just try. I will match you, I swear it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Like you, Grandma... My alchemy will bring happiness to the people."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4a,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hahaha. It's always been my dream, but to be honest, I never thought it would come true."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "But my friends have changed my mind. I know now that my dream can be a reality."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "With their help, and with a little experience, I know that my dreams can be realized."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "That's why I figure that now's the time. I'm going on a journey to reinvent myself."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "So, Grandma... Please, watch over me!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Well, then... Until I return!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "...Okay! I'd better just check I haven't forgotten anything!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Oh yes, which reference books should I take with me? Plachta would know..."
        }
    ]
}