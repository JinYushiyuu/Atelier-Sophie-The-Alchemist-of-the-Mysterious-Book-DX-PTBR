{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_XX01_110.ebm",
    "nb_messages": 0x22,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Sophie... Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x1,
            "msg_string": "Oh, Cory! What's up today?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "...Sophie. You said you wanted to be like your grandmother, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Huh? Yeah, absolutely! My ultimate goal is to become as great an alchemist as Grandma!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "...Why do you ask?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "I want to help... After all, you've always helped me..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I wondered... if maybe I could help you in your quest to become more like your grandmother..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Cory...! That's so thoughtful of you! Thank you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3f,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "So I asked around in town, to see what people remembered about her..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "She was a great alchemist... But she also seems to have been very strong in battle..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yeah, that's right! She used to swing her staff around and defeat all sorts of monsters!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yes... There are many legends... The most famous seems to be the \"Ghosts on the Moor\"..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "They say she defeated some terrible ghosts that appeared on the Moon Sun Moor all by herself..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Oh yeah, I remember hearing about that when I was younger. I don't know the details, though..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "That's why I brought you this..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "What's this? A request? \"Can you please defeat the ghosts on the Moon Sun Moor\"...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I think you should do it, Sophie... Defeat the ghosts on the moor..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "If you do... Then you will be one step closer to your grandmother..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "What?! That's what you want me to do?! No way! I can't do that!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "You know I'm scared of ghosts, Cory! This is a nightmare! I can't accept this request...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Sophie... Do you not want to be like your grandmother after all...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Ugh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Your grandmother... They say she accepted any request that came her way, no matter what..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "...But you don't want to be like her...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "Ohh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Don't you want...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "O-Okay, okay! I get it! You want me to do it, right?! I'll do it!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x1b,
            "msg_string": "Yes...! This is a big step for you, to get closer to your grandmother...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x1c,
            "msg_string": "Oh, dear... I never thought you'd do something like this to me, Cory..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "But you're right. I can't spend my whole life being afraid of ghosts."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Okay. Wearing my grandma's clothes, I'm sure I'll be all right. I'll get those ghosts...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x48,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Please, Grandma...! Give me your strength!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "I knew you had it in you, Sophie... Once you're ready, let's head out..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x21,
            "msg_string": "Scary ghosts are waiting for us on the moor..."
        }
    ]
}