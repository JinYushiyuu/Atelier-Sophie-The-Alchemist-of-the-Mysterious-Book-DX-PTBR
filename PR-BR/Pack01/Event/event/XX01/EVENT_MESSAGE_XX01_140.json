{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_XX01_140.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, I did it... I won... Did I?"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0x60,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "Whoo-oo-oo-oo...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0xe,
            "msg_id": 0x2,
            "msg_string": "No! There are more of them! I can't take it anymore!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "...! Corneria!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I understand...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hah!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "There!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Whew... Sophie, are you okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x54,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Ah, ah... Monika! Cory! Thank you...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Not at all... I'm sorry, Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x24,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "I knew how much you were afraid of ghosts... It was too much to ask..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "I'm sorry too, Sophie... I shouldn't have pushed you like that..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Both of you... Please, you mustn't feel bad!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I was scared of the ghosts... But I know you both did it for me."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x3f,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "So I can't complain. In fact... I owe you a debt of gratitude!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Grandma once told me that friends are the most important thing of all."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "I am truly blessed to have friends who are doing everything they can to help me!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x1a,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Hehe. Monika, Cory... I hope you'll keep being my friends!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Of course we will...! I hope I can ask the same of you."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I feel the same way, Sophie! I'm so glad to have you as my friend."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Let's go home. Before any more ghosts appear..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Ah..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x17,
            "msg_string": "Hm? What's wrong? Monika? Cory?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "Um... Sophie, behind you..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "Eh?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2a6,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "No! More ghosts! I just can't stand ghosts! Aaaarghhh!"
        }
    ]
}