{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_MON_310.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "It's unusual to see you here at this time, Monika."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yes, I wanted to talk to the singer here."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Huh? The singer?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I wanted to ask about work as a professional singer from someone in that field of work."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I wanted to know what it's like to sing as a career, and what kinds of places one could expect to work..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I see, I see."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I also wanted to know how much money one could earn, and how much demand there was for performances."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "...You're taking this really seriously."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Those are all important things to know. I wanted to know beforehand, so I could take it into consideration."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Huh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Anyway, thank you for your help, miss."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Sophie, you shouldn't walk around too late at night either."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Yeah, I know. I'll be careful."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Good. Then I'll see you again."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Okay, bye bye."
        }
    ]
}