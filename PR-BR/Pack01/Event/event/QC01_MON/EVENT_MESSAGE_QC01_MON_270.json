            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yes, we were. There are other people I get along with, but the three of us always seem to be together."
