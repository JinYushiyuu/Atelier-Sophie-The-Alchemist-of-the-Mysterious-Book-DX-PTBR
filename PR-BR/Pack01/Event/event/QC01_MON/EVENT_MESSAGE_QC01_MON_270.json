            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Really? I think you're all pretty similar."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0x27,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
