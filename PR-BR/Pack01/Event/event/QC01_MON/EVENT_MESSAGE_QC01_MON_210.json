            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, Oskar and Julio. Are you here to listen to Monika sing?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Yes. Oskar invited me."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "This is Monika's big debut, of course we're here to listen. We saved a seat for you, too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Thanks."
