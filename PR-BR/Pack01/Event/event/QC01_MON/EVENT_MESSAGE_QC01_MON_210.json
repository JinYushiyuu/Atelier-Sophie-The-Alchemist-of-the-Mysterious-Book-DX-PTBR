            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Thank you for waiting, everyone. We'll be starting the concert now."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Today's singer, Miss Monika, will be entering the stage now. Please give her a round of applause."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Monika!"
