        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Is she alright? She looks really nervous..."
