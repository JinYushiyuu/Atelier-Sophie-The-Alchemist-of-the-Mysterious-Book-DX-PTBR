{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC01_MON_260.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, Sophie. It's unusual to see you at the bookstore."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yeah. What kind of book are you looking for?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Hmm, there's nothing in particular that I want, but I was thinking about buying anything that looks interesting."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "You read all kinds of books, Monika."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Yes, although not as many as you, Elise."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hey Monika, why do you read so many books?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Well... I want to know a wide variety of things, so it's mainly out of curiosity."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "There's no harm in knowing many things."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Wow, you're really enthusiastic about it."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Really?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x40,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yeah. But it's not good to read too much, you know? Both you and Elise have to wear glasses."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "My eyesight isn't as bad as Elise's. I can get by fine without wearing my glasses."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I don't mind, as long as I can read. But you use a sword, Monika. Is it really okay for you to have bad eyesight?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "I'm fine if I have my glasses on. Besides, these glasses are very light."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hmm, that sounds convenient."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Sounds like there's all kinds of glasses."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yes. It's something I wear everyday, so I worry about it more than clothes."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "It's like a part of your body."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I didn't know..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Anyway, I'll be going now. See you again."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Yeah."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Come back anytime."
        }
    ]
}