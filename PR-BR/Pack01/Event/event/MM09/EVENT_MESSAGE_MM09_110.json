            "voice_id": 0xb,
            "name_id": 0xb,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Ahaha, that's not how I meant it. It's just... You seem more grown up, I guess..."
