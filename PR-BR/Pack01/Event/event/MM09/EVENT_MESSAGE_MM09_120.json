            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ahaha, no particular reason... There's just something I'm curious about."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "...I see. Well then, let's see..."
