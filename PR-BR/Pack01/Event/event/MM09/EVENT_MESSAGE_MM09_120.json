            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yes, of course. What kind of book is it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Um... I want a book that's about the past..."
