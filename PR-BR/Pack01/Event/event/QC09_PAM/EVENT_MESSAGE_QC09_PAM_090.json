{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_PAM_090.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "(Huh...? That's Pamela and Mr. Horst. And Mrs. Marguerite is there too?)"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "I see... That's a difficult issue."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "When it comes to issues facing the entire town, we can't make decisions alone."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Still, we can't just ignore it."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "That's true..."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Then we just have to do something about it."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "You're rushing too much, Marguerite. You were always like this, ever since you were a child."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "You have plenty of time to think about it first. Nothing will happen anytime soon."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's... I suppose so."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "There's some truth to what Pamela said. We should think about it a while longer."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Hmm, you're right. I got it, I'll leave this matter up to you for a while."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Yes, I'll take charge of the matter. It was good that we came to Pamela to discuss it."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "We always come here when we're concerned about things, ever since we were kids."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Hehe, you're welcome anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(That conversation was a little strange... And exactly how old is Pamela...?)"
        }
    ]
}