{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_PAM_190.ebm",
    "nb_messages": 0xf,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Um, Sophie?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "What is it, Pamela? You have a serious look on your face..."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3f,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "I wanted to thank you for buying so much."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "But Sophie, you aren't overspending, are you?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "H-huh!?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I'm happy you buy so much from me. But you shouldn't ever waste money."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "You should only buy what you need. Throwing away extras because you have too much is bad."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "I-I think I'm doing fine..."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "You need to learn how to manage your money from a young age."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "If you don't, you'll have trouble later."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "You're especially too nice to people. Some bad people might take advantage of you and make you work for their benefit."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Uu... Now that you say that, I'm starting to feel like I'm in danger..."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "You need to plan how you use your money, so you can still manage if something like that happens."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "I-I got it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "(...Pamela's acting like she's my mom.)"
        }
    ]
}