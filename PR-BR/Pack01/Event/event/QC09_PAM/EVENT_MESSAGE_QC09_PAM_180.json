{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_PAM_180.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Here you go. Thank you as always, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Thank you too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "By the way... There's something I wanted to ask you."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "What could it be?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Do these talismans really have any effect?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "How rude, of course they do!"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "They're effective for everything, from healing wounds to supplementing nutrition."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "They're talismans from a church. How could you even think they have no effect?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "I... Guess so...? They must be full of God's power or something?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "That's right. Those talismans are filled with power thanks to the townspeople's prayers."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Ah... Now that sounds pretty amazing."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "But they've been a little too popular lately, and I'm having trouble making enough of them."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Sophie, do you think you could help?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Huh...? You're making these?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "That's right. I make them all by hand, one by one."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hmm... Maybe they aren't filled with God's power after all..."
        }
    ]
}