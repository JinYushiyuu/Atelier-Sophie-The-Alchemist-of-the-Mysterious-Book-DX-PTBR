{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_PAM_160.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "(I couldn't figure out how old Pamela is... In that case...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "(I just need to ask her directly!)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Pamela!"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh dear, what's wrong Sophie?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "Pamela, how old are you!?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Hmm... Now how old was I?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Don't try to dodge the question, just tell me!"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "I'm not trying to do that. I really don't remember how old I am..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "What...? You don't remember...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "To be honest, I died a long time ago. That's why I decided to stop counting my age."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Huh...? You died?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "That's right."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Wait... What does that mean... Wait, does that mean you're a ghost?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "That's right too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "WHAAAAAT!? Y-you've got to be joking! I mean, you're talking like normal, and walking around..."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x2a,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "You say that, but it's true that I'm dead. I can't help it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "That's... I guess so... But why... How?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "It's not like you lose your free will when you become a ghost."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "In fact, it's pretty convenient."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Ahaha! Are you serious?!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "So that's why you know so much about this town, and the past?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "That's right. I've been in this town ever since I became a ghost."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "I-I see... And I was trying to find a serious reason to explain it."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "I'm sorry. But I wasn't trying to hide it or anything."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "No, no, it's okay. It's my fault for worrying about it so much."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Hehe, please continue to visit the church, okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Yeah, I will."
        }
    ]
}