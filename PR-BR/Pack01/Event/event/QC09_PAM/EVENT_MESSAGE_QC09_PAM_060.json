{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC09_PAM_060.ebm",
    "nb_messages": 0xd,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Huh? Pamela?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, Sophie? What a coincidence, good evening."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Good evening. It's unusual to meet so late at night. What were you doing?"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I finished cleaning the church and taking care of the children early, so I came outside for a little fresh air."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "The night wind feels really nice here. Do you like the night, Sophie?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Hmm... If I had to choose, I like day more. Night is... It's dark, and a little scary..."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Oh dear, that's too bad. Night is really nice."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "The voice of the wind along the roads, the sounds of insects, the murmurs of the river, the rustling of leaves..."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "There are so many little voices that can't be heard during the day. The night teaches us many such things."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "You're actually... Really cool at night, Pamela."
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "Hehe, would you like to take a night walk together sometime? Of course, it would be in town..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Wow, that sounds fun! I'd love to go!"
        },
        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Okay then, we'll do that sometime."
        }
    ]
}