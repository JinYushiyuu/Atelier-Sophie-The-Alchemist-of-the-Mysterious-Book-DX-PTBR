{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS12_100.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Okay! The tent's done!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Very nice, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x47,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yeah, thanks... Now we're all set for the journey."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Indeed... We can set out anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Yup... Hey, Plachta?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Yes, what is it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "When we go on our journey... And travel really far from this town... What could be waiting for us?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "...Who knows? We'll just have to go and find out."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Ahaha, I guess you're right."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "...However. There's one thing I wish to say."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Huh...? What's that...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Regardless of what we encounter on our journey... Or what may occur..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "As long as we're together, there's no mistake that it will be an enjoyable journey."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4a,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yeah! I think so, too! As long as I'm with you, it'll be a fun journey."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "...Oh, I'm getting kind of hungry."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "You too? To be honest, I was as well..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ah, I see... Then I think this is a good time to eat."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yes, you're right. Let's do that."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yup! I'll cook up something great with everything I've got!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0xc,
            "msg_id": 0x13,
            "msg_string": "Hehe. I'll be waiting eagerly, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "(I don't intend to travel for a little while longer... But I'll definitely leave this town eventually.)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "(Of course, it's sad to leave. I won't be able to see the people I've seen every day.)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(It'll probably be a long trip, and I can't even imagine what will happen along the way.)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "(...But I have a friend I cherish. Someone who's like family to me, who's always with me.)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "msg_string": "(That's why I believe... No matter what kind of journey it is, as long as I'm with Plachta...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "msg_string": "(I'm sure it'll be a wonderful, mysterious journey!)"
        }
    ]
}