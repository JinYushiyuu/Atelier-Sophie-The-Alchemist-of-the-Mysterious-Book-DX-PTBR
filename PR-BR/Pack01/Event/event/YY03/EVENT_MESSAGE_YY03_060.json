{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_YY03_060.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hey, Oskar? There's something I want to ask you..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hm? Troubled by something? I'd be willing to listen."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Okay, then... Um... If, and I just mean \"if\"..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "If you were to leave this town, to travel really far away... What would you do?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "What would I do...? Nothing in particular. I'd just enjoy my travels."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Huh...? But you wouldn't feel lonely? You wouldn't be able to see me or Monika, you know?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Sure, I'd be a bit lonely, but... It's not like we'd never see each other again."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "And if I really wanted to see you that badly, I could just turn back part way through the trip..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I don't think it's really that much to think about, personally."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "Hmm, true... I guess that's right..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "What? Don't tell me... You plan to go on a journey?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "...I don't know. I'm kind of thinking it through right now..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I see... If you go on a journey, I'd go along with you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "What...? Really...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yeah, of course! I could meet all kinds of plants if I travel!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x43,
            "expr_id": 0xc,
            "msg_id": 0xf,
            "msg_string": "A-ahaha... That sounds like a reason you'd come up with..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Besides, it would be dangerous if you were alone."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Anyway, I don't think you need to worry so much about going on a journey."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "...Yeah, you're right. Thanks, you really helped!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "No problem!"
        }
    ]
}