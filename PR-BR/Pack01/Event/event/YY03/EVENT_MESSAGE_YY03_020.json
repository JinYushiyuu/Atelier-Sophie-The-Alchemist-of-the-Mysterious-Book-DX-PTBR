{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_YY03_020.ebm",
    "nb_messages": 0x21,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Sophie!"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Please look at this!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Huh, wait... This is...!"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Yeah! We made it!"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x4,
            "msg_string": "It's been a while since we made something using normal alchemy..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "Congratulations! That's great, you two!"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "Heh heh... We really don't have enough words to thank you."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Anyway, there's something we need to tell you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Huh... What...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "It's not a big deal. We're just thinking of traveling again."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "So we came here to say farewell."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Oh, I see... It'll get a little lonelier around here. So, do you have a goal for your trip?"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "A goal? Let's see..."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Now that we can use alchemy again... Maybe we'll take over the world this time...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xc,
            "msg_id": 0xe,
            "msg_string": "There you go again. I know you aren't thinking about that."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "...Grr. It's no fun trying to tease you lately, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x9,
            "msg_id": 0x10,
            "msg_string": "Ahaha, sorry."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "...You already know, don't you? If you abuse that tool for wickedness..."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yeah, of course. We already know what it's like to be beaten up by Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x13,
            "msg_string": "Good... Be careful."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "...You too. Don't cause too much trouble for Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x15,
            "msg_string": "Wha!? I never cause trouble for her...!"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Sophie. Plachta isn't very good at taking care of herself, so you need to watch over her."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xc,
            "msg_id": 0x17,
            "msg_string": "Yeah, I know."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x18,
            "msg_string": "Y-you too!?"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Haha. Anyway, we'll get going now."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "We'll be looking forward to seeing just what kind of alchemist you become... Farewell."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "...They left. The atelier feels a lot more empty now."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "...Yes. Goodness, those two were rude right up to the last minute."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Haha. Now then... Maybe I'll study a bit of alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "You should watch, Plachta. I'll probably have some questions."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "You seem motivated. Very well, I'll guide you properly."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x20,
            "msg_string": "Yeah, thanks!"
        }
    ]
}