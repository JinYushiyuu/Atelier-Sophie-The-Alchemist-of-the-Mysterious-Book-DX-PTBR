{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_YY02_080.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Nnnnn... I didn't expect it to be this hard to come up with..."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Sophie. To tell the truth, we've been curious... You're concerned about something, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Huh...? How did you know...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Of course we would realize it. We've known each other for a while now."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "...That concern. It's about Plachta, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "We might look like this, but we're your seniors in life... Try talking about it, we'll listen."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "You two... Okay then, I'll talk. So you see..."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Interesting... So you're concerned about Plachta not having a human body."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Yeah... I was thinking about how we sense all kinds of things in different ways."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "And that's why you wish to give Plachta a human body...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Yup. But I couldn't do it before... I'm worried if I'd even be capable of it..."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "Heh heh... Ahahahaha! To think you were concerned about something like that!"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Hehehe... I laughed so much, I started crying..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Uu, that's right... I know trying to give her a human body is ridiculous..."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "Hm? What are you misunderstanding? That's not what we were laughing about."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Huh...? What do you mean...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "...Who knows? We should go, Meklet."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yeah, you're right. Still, you really are an interesting one..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x44,
            "expr_id": 0xf,
            "msg_id": 0x12,
            "msg_string": "H-hey! I thought you were going to help me with this!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Ugh! It wasn't worth getting laughed at!"
        }
    ]
}