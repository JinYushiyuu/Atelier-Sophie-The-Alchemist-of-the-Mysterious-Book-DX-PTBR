        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "extra_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "As you know, we were originally the same person. We share the same soul, so I doubt you can call us siblings."
        },
        {
            "type": 0x2,
            "voice_id": 0xe,
            "name_id": 0xe,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "But these bodies were basically made at the same time. In that sense, you can say we're siblings."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "I see... I guess that means you're like half siblings..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Okay then. Are you the older one, Meklet? Or would that be you, Atomina?"
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0x29,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "Of course..."
        },
        {
            "type": 0x2,
            "voice_id": 0xf,
            "name_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Of course..."
        },
        {
            "type": 0x2,
            "voice_id": 0xffffffff,
            "name_id": 0x29,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "I'm the older one.<CR>I'm the older one."
