{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM06_040.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4f,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "That should do it. The book is filling up quite a bit."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "You're right. Your skills with alchemy have grown quite a lot too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Really!? Yay, I got a compliment."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Only compared to the beginning. There's still much you need to study and learn."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x54,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Oh, I see... I guess I still have a long way to go..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "The path of the alchemist cannot be walked in a day. Anyway, I'll look at the recipe."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "...Uu!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Plachta!? What's wrong, are you okay!? Hey!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "...Haah, haah... I'm... Okay..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "...What did you remember?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "...To be perfectly honest, even I'm confused."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "...Can you tell me what it was?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "...It was a memory of me fighting. Only a single scene, of me fighting something. That's all I remembered."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "...That's it. I don't know who or what I was fighting, where I was, or the reason... I don't remember any details."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "But it seemed very important..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "I feel as though I was fighting to protect something very important. Something that shouldn't be forgotten..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Plachta..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I'm sorry, Sophie. For now... I don't want to think about it anymore."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Okay..."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Plachta told you about a new gathering field that she remembered."
        }
    ]
}