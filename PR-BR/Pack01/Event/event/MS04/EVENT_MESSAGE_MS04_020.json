        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Um, Sophie? Is she the one coming with us?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x40,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Yeah, this is Cory."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "My name is Corneria. It's nice to meet you..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Um, it's nice to meet you too."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Oh, so it was you."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ah, Oskar. Hello."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "You know her, Oskar?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yeah. She has a store near mine. I go there sometimes too."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Are you looking for things to sell at your store, Corneria?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Yes. I figured I should widen the variety of my merchandise."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Alright then, I guess we need to work extra hard."
