            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Looks like we're all here. We should depart soon."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Wait a minute! There's going to be someone else coming with us starting today."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hm, really?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "I'm sorry I'm late..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ah, Cory. You really are late."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x24,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "I'm sorry. It took a while to prepare..."
