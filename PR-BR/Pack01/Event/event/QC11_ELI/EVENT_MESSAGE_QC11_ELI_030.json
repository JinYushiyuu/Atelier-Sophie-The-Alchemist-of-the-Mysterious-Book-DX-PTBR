    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ah, Elise."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hello, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hello. Why are you in a place like this?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I at least need to go outside on my days off. Staying inside all the time is unhealthy..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "So you're taking a walk? Did you walk a lot?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3f,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "No, I was just reading over there, so I hardly walked at all."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "Wait, you read books when you're outside too...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Yes, that's right."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "But then it doesn't really make a difference if you're outside or inside..."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "That's not true. Reading as a gentle breeze softly blows by is a much different feeling than usual."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Huh... I guess it is different, now that you mention it..."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Ehehe. Picturing you reading under a quiet, shady tree is kind of nice, too."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "D-do you really think so...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yeah, I think it would be picture perfect."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "Hehe, really? Thank you."
        }
    ]
}