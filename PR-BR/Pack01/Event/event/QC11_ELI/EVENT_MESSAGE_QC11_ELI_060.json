            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello... Wait, huh...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Welcome."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Huh...? Where's Elise...?"
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x2,
            "msg_string": "It's me. What's wrong, Sophie?"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x2,
            "msg_string": "Wait, what...? Elise...?"
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x2,
            "msg_string": "Yes, it's me... Really, what's wrong?"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x2,
            "msg_string": "B-but, um... You're way different from usual..."
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x2,
            "msg_string": "I am?"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x2,
            "msg_string": "Yeah... Oh, I know... Your glasses!"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x2,
            "msg_string": "What happened to your glasses?"
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x2,
            "msg_string": "I have them."
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x2,
            "msg_string": "I read a little too much, so my eyes are tired. I took my glasses off to give them a rest."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x2,
            "msg_string": "I see."
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x2,
            "msg_string": "I don't really understand, but do I really change that much without my glasses?"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x2,
            "msg_string": "Yeah, you look super pretty!"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "unknown2": 0x2,
            "msg_string": "Oh wait, um... You're really pretty to begin with, but, um..."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "unknown2": 0x2,
            "msg_string": "You look more colorful, or... Hmm, I'm sorry, it's really hard to describe."
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "unknown2": 0x2,
            "msg_string": "Hehe, that's fine. Don't worry about it."
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "unknown2": 0x2,
            "msg_string": "But I can't read books without my glasses."
        },
        {
            "type": 0x5,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x13,
            "unknown2": 0x2,
            "msg_string": "I can recognize you by your voice right now, but your face is very blurry."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "unknown2": 0x2,
            "msg_string": "So your eyes were that bad..."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Yes, there's no way to make them better. It's really not something I can do anything about."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "(Hmm... This feels like a real waste...)"
        }
    ]
}