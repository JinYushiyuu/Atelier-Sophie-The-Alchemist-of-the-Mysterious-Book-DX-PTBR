{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC11_ELI_130.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Huh? Elise?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, Sophie. Welcome home."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "S-Sophie. I-is it true that Plachta turned into a human?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Hmm, technically her body is a doll, not human."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Thanks to everyone, I was able to obtain a new vessel."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "So that's what happened. But this is hard to believe... A book turned into a doll..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ehehe, are you surprised?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Of course I am. This is one case where truth is stranger than fiction..."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I don't even know how to explain my thoughts on this... Alchemy really is amazing..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "I agree."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Um, Plachta... This might be a rude question, but may I ask...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I don't mind."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Did you dislike being a book...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "That's not really the case. However, now that I've taken human form, I can do much more."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I wanted to read books, for one. That wasn't really possible as a book."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "...Hehe. That's true."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Do you mind if I visit your store one of these days?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Come anytime. Customers who love books are always more than welcome."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Ehehe, that's great, Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Yes. Now I have another thing to look forward to."
        }
    ]
}