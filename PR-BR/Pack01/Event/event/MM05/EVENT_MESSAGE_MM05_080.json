{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM05_080.ebm",
    "nb_messages": 0x19,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hey Plachta. Do you remember our promise from before?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Our... Promise? Wait, do you mean..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yeah, that one. Our promise that, when you turned back into a human, we would go places together!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Well, you technically aren't a human, you're a doll, but... Ehehe, good enough."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "...I see. Then I would love to go with you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "That's great! Then let's go!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ah, there. Look at that. They're selling some fun stuff! Unlike before, now we can actually go and take a look."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "That's right. Let's take a look."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "What do you think, Plachta? Doesn't Mr. Horst's tea have a really nice aroma?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yes, it seems to be very high class."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "It tastes really good too. You should try it."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "...Would this body have any problems if I eat or drink things?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Huh? Hmm... Ahaha, you'll be fine... I think."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Wow, that was fun!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yes. We browsed various items, and having tea with you was a splendid experience."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "I feel like it's been a while since I had this much fun."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "That's right. In my case, it's been 500 years. I had forgotten that it was this enjoyable to actually have a human body."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x6a,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "...I was able to remember all this thanks to you as well, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Ehehe... It was well worth all the work if you're happy, Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "...But this is only the beginning. Your memories still haven't come back, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I guess I can say this is still the halfway point."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "My final goal is to reclaim all your memories! ...I made a promise, after all."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "So to do that, I'm going to work even harder with alchemy."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Sophie learned the skill \"<CLGR>Perseverance<CLNR>\"."
        }
    ]
}