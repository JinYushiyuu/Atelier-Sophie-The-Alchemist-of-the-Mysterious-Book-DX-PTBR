    "nb_messages": 0x13,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "This is the furthest inside."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yes, I believe so... We didn't spot any clue of their presence, though."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "Oskar?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Huh, that's weird... I could have sworn I saw them..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh! Maybe... They noticed we were here, and hid somewhere?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "I don't know..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "I'm sure of it! Let's try searching every nook and cranny!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Whaaat? Okay, fine. We'll try looking around a little more..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "See!? They weren't here!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Looks like those two are really good at hiding..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "No, I doubt that's the case..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "...I'm going to tell Mrs. Marguerite about you ditching work."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Wha!? W-w-wait, give me a break!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Meklet! Atomina! You're here, aren't you!? Come out for my sake, please!!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "No way..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4e,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I was joking. I won't tell her, don't worry."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Sophie...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Well, we can't help it if they aren't here. We should return to the atelier, albeit reluctantly."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yeah, you're right. Let's go."
        }
    ]
}