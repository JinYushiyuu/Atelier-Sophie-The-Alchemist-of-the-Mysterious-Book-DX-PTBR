            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Hey, I can hear the piano... I guess someone's playing it..."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x2,
            "msg_string": "Mr. Horst... That's amazing..."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x2,
            "msg_string": "Mr. Horst!"
        },
        {
            "type": 0x5,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x2,
            "msg_string": "Ah, Sophie. Welcome."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x2,
            "msg_string": "You're acting like nothing happened? You were able to play the piano all along!?"
        },
        {
            "type": 0x5,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x2,
            "msg_string": "Yes, somewhat."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x2,
            "msg_string": "Somewhat...? You're really good!"
        },
        {
            "type": 0x5,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x2,
            "msg_string": "I'm not good enough to play for customers."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x2,
            "msg_string": "Aah... If you're able to play so well, you could have taught me..."
        },
        {
            "type": 0x5,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x2,
            "msg_string": "My playstyle isn't really suitable for teaching. It's all self-taught."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x2,
            "msg_string": "Really?"
        },
        {
            "type": 0x5,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x2,
            "msg_string": "That's right. There are plenty of people who can play far better than me."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xc,
            "unknown2": 0x2,
            "msg_string": "Hmm... But I see you like playing the piano too."
        },
        {
            "type": 0x5,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "unknown2": 0x2,
            "msg_string": "Haha, I don't know if I like it, per say. I simply play it on a whim."
        }
    ]
}