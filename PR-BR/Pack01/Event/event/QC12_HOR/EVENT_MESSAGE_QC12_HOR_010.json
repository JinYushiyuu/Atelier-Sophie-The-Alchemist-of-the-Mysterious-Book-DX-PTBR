{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC12_HOR_010.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Good evening, Mr. Horst."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Sophie. Welcome. It's unusual to see you here at a time like this."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Ehehe. I figured a night walk could be nice."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x3,
            "msg_string": "The night air is quite pleasant, after all."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "It's completely different from daytime here."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Yes, it is. I actually serve alcohol to my customers here at night, too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Huh, you serve alcohol...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "At first, I was simply open late for my customers who couldn't come during the day."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "But there were quite a lot of requests from my night customers for alcoholic drinks..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "That's why I only serve it at night."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "I didn't know at all."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Before I knew it, my cafe was more like a bar at night."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Do you serve different food too?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Of course. I serve food that goes well with alcohol."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "That sounds nice... I'd like to try some. Oh, but maybe not the alcohol part..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I can serve you just the food, but it really is intended to compliment drinks..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Well... You can always try it when you're older, and able to drink."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x40,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Okay."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Of course, you're always welcome at my shop, regardless of if it's day or night."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Come whenever you like."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Ehehe. Okay, I'll come back again."
        }
    ]
}