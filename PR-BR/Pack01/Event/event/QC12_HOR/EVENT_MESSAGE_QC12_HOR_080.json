            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "By the way Sophie, have you seen my foolish son around? He disappeared again."
