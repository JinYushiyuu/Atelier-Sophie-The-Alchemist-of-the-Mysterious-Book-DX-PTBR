{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC12_HOR_020.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Mr. Horst."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Welcome, Sophie. What do you need today?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "There's nothing in particular... But do you mind if I ask you a question?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ask whatever you'd like. I'd be more than happy to answer, if it's something I can."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "You're running a cafe, so why do you manage all kinds of other work?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ah, that. There's no major reason for it..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "In the past, this shop had a bulletin board for guests to interact and post notices."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "A bulletin board...?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's right. One day, a certain guest posted a request with a monetary reward on the board."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "After that, the board was used more and more for such requests and business."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Huh..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "However, there were too many people using the board, and it turned into a complete mess."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "That's why I decided to take charge and manage all of it myself."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "So that's why... I'd never heard of that... But isn't it a lot of work?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "That's very true... But I do receive commissions."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xf,
            "msg_string": "On some days, it even exceeds the amount of money I make from cafe sales. It helps a lot."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Anyway, you should do your best to fulfill them too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "What happens if I do?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Greater accomplishments allow you to accept more difficult, yet better paying requests."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "I have great expectations of you, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Y-yes, I'll do my best!"
        }
    ]
}