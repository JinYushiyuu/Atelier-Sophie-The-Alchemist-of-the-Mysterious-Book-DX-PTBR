    "nb_messages": 0xe,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Huh, who could that be? Yes?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hey, I'm coming in, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Ah, Oskar. Huh? Could that be..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Yup, that's right. The \"Haze Grass\" grew flowers. Here."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x2,
            "msg_id": 0x4,
            "msg_string": "Wow, what a pretty flower..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "But is it really okay? You worked so hard to grow this..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x10,
            "msg_id": 0x6,
            "msg_string": "...That's what it wanted."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Huh?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x10,
            "msg_id": 0x8,
            "msg_string": "The flower. It wanted to repay the person who made it such great fertilizer... That's what it told me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "The flower said that...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3e,
            "expr_id": 0x10,
            "msg_id": 0xa,
            "msg_string": "Yeah. That was its decision, so I respected that choice."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x10,
            "msg_id": 0xb,
            "msg_string": "That's why, Sophie... I want you to use it with care."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Oskar... Yeah, I will! Thank you!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "...Thank you too. I'll take good care of you."
        }
    ]
}