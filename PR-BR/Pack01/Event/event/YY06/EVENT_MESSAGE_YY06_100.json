{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_YY06_100.ebm",
    "nb_messages": 0x1a,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "よーし！<CR>テント、できあがりー！"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "お疲れ様です、ソフィー"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x47,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "うん、ありがとう。<CR>…これで旅の準備、揃ったね"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "ええ。<CR>…いつでも、旅に出ることができますね"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "うん。<CR>…ねぇ、プラフタ"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "はい、何でしょう"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "旅に出て…この町からずーっと離れたところにはさ。<CR>一体、何があるんだろうね"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "…さぁ。<CR>それは、行ってみないとわかりません"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "あはは。<CR>そりゃそうだよね"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "…ですが。<CR>私には一つだけ、言えることがあります"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "え…？<CR>どんなこと…？"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "たとえ旅の中でどんな物があろうと…<CR>どんな出来事が起ころうと…"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "あなたと一緒であれば、<CR>間違いなく楽しい旅になるということです"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4a,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "そうだね！あたしもそう思う！<CR>プラフタと一緒なら、きっと楽しい旅になるよ"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "…おっと。<CR>なんだか、お腹すいてきちゃった"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "あなたもですか？<CR>実は、私も…"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "あ、そうなんだ。<CR>じゃあ…キリが良いから、ご飯にしようか"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "ええ、そうですね。<CR>そうしましょう"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "うん！<CR>じゃあ今日も、腕によりをかけて作っちゃうから！"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0xc,
            "msg_id": 0x13,
            "msg_string": "ふふっ。期待していますよ、ソフィー"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x14,
            "msg_string": "（旅に出るのは、もう少し先にするつもりだけど…<CR>それでもいつかきっと、あたしはこの町を離れる）"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "（もちろん、この町を出るのは寂しい。今まで<CR>毎日会ってた人に、会えなくなっちゃうわけだから）"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x16,
            "msg_string": "（たぶん長い旅になるし、<CR>どんなことが起きるのかもぜんぜん想像がつかない）"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "（…でも、あたしには大切な友達がいる。<CR>いつまでも一緒にいてくれる、大切な家族がいる）"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x18,
            "msg_string": "（だから、あたしは信じてる。<CR>どんな旅でもプラフタが一緒なら、きっとーー）"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "msg_string": "（きっと、とっても不思議で…<CR>とっても素敵な旅になるって！）"
        }
    ]
}