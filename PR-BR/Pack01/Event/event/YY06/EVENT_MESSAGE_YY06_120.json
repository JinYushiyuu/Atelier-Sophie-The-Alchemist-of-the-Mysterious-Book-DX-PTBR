{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_YY06_120.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "うーん、そうだな…。<CR>もっと先端を鋭くしてみるか？"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "いや、それだと植物を傷つけちゃうだろ。<CR>もっと何か別の方法で…"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "あれ、オスカーがここにいるって珍しいね"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "お、ちょうど良いところに！<CR>お前も混じってけ！"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xf,
            "msg_id": 0x4,
            "msg_string": "え？え？"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "今、オスカーのシャベルの改良案について<CR>話していたんだ"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "ああ。旅に出るなら、今までよりすごいシャベルを<CR>使わないとダメだと思ってな"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "ああ、なるほどね…"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "…どうだろう。いっそのこと、<CR>変形機構を設けてみるというのは？"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "うーん、それも悪くないけど…。<CR>オイラとしては、やっぱりドリルがだね…"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "へ、変形！？ドリル！？<CR>えーと…これってシャベルの話…だよね？"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "もちろん。<CR>何か良いアイデアはないかい？"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "アイデアって言われても…。<CR>先っぽが伸びるようにする…とか？"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "…！<CR>それだ！"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "ああ、これは盲点だったな…。<CR>さすがソフィーだ！助かるぜ！"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "（…うう、どこが良かったのかぜんぜんわかんない。<CR>でも、二人ともとっても楽しそう…）"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xffffffff,
            "msg_id": 0x10,
            "msg_string": "（こういうのが好きって…<CR>やっぱり二人とも、男の子なんだなぁ…）"
        }
    ]
}