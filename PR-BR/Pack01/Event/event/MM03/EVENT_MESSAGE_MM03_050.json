        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "That's good. Come back and visit anytime."
