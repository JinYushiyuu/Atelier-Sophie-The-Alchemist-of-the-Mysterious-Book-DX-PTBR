        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "N-no, it's fine. Thank you Pamela. You really helped!"
