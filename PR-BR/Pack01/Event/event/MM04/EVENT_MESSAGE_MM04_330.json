        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x40,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yeah. Anyway, this is another step forward in Operation Humanize Plachta!"
