            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Yes, I believe this will suffice as the vessel for Plachta's soul."
