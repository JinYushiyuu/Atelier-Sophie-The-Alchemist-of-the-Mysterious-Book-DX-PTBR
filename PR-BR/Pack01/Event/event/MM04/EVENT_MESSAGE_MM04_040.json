            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "The body of a young woman, complete with beautiful curves and features! And of course, it's both strong and durable!"
