            "type": 0x2,
            "voice_id": 0x5,
            "name_id": 0x5,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "This is it... This really is it! This is my greatest masterpiece!"
