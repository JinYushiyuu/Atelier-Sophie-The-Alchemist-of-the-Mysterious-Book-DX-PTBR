            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "A-ahaha... I see... But this doll really is cute..."
