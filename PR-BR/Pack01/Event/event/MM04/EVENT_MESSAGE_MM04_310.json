{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM04_310.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Leon, I finished the cloth you wanted!"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Good, as I expected from you. This elasticity should be perfect."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Yay! That means you'll be able to make Plachta's clothes, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Yup. Although, before that... There's one thing I want to ask you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Okay? What is it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Why did you decide to have Plachta wear clothes?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0xc,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "This might sound wrong, but... If it's just a doll, you don't really need it to wear clothes."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "That's because... Plachta's a girl, for one, but also..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Plachta's like family to me. I wanted her to get to wear something pretty."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Is that not enough...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "...Hehe, maybe that was a mean question to ask. There's nothing wrong with that."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I wanted to see how you felt. Your answer would affect the clothes I make."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Really? Uu, you kind of scared me for a moment..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Sorry about that. But I know just how much you cherish Plachta now."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Just leave the rest to me. I'll make the greatest clothes for her, filled with your feelings."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Okay! Thank you!"
        }
    ]
}