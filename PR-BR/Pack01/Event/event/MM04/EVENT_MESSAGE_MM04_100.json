        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ah, yes. Here it is."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Is this an alchemy recipe...?"
