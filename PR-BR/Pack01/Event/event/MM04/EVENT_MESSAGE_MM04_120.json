{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM04_120.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Logy. There's something I wanted to ask you..."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Ah, Sophie... What is it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Have you ever heard of a \"Soul Stone\"?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "Did you just say \"Soul Stone\"? Sophie, where did you hear about this?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Um... Was it something bad?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "No, not really. It's just a very rare material. It's pretty close to a legendary stone among smiths."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Wait, really?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Yeah. It's round, and very smooth, almost like it was polished by something."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "If I recall, the last time I saw one was about 20 years ago."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "20 years!? That long ago!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3e,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Yeah, I think I found it at the Prospector's Strand."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "I-I didn't know it was that rare... Uu, what should I do..."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "If you really need one, maybe you should just go and check for yourself?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Huh? What do you mean?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "\"Soul Stones\" have some mysterious qualities. I have no idea why, but they're found at set intervals."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "The last one was found 20 years ago. The one before that, and before that, were all found about 20 years apart."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Then maybe if I go now..."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2e,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Yeah, it's possible that you could find one. I think the chances are decent enough."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "But is it really okay? Wouldn't you want to have the Soul Stone too...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Nah, I'll pass. I have nothing to use it for. Besides, it sounds like you really need it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Logy...! Thank you so much! I'll go check!"
        }
    ]
}