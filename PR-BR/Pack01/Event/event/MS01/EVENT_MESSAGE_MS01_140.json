{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS01_140.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "I see, that's good to know. Thanks."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Not a problem."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "What were you talking about?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Ah, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hey. I was just giving her some advice about clothes."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "What!? You were, Oskar!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "...Why are you so surprised?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Because I didn't know you had interest in clothes. And you were giving Leon advice? ...Shouldn't it be the reverse?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "What? I can give some advice too. It's not about color or fashion, anyway."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Wait, then what was it about?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "He's kind of plump, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I figured he would want different clothes than people with more average builds, so I asked him for his opinion."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Ah... So that's what it was."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "He was really helpful. I think I can still make some improvements for comfort when it comes to clothes like this."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "You can come to my store anytime if you have more questions. My mom's always there."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Oh, does that mean your mother made the clothes you're wearing?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yeah, that's right."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Mrs. Marguerite is really skilled. She's good at cooking too, I really admire her."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I see, then maybe I'll go talk to her sometime."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "You're always welcome. Even more welcome if you buy some vegetables while you're there."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x14,
            "msg_string": "Ahaha, there's the real motivation."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x15,
            "msg_string": "Hehe, maybe I'll do that."
        }
    ]
}