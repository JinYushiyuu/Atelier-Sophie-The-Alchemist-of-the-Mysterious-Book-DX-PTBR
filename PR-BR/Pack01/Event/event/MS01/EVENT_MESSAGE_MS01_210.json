            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Well you see, Mr. Horst hired me to sing at his shop."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x3,
