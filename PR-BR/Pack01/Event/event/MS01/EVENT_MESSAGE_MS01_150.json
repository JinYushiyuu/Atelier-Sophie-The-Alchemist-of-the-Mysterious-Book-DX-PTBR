            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "It seems like the weight would cause it to shift or slip off..."
