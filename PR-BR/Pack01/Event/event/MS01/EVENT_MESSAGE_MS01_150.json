        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I see! I didn't think of that... I think that would work."
