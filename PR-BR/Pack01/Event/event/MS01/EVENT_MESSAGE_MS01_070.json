{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS01_070.ebm",
    "nb_messages": 0x16,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Thank you, you always do excellent work."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Thank you too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hello."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Oh, Sir Julio."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hello, Sophie. What a coincidence."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Yes. Did you come here for sword repairs?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "That's right. There aren't many places that can handle such a large sword."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I'm very grateful to Logy for this."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "Don't worry about it, this is just my job."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x9,
            "msg_string": "But I'm surprised you can wield such a large sword. It must be troublesome just carrying it around."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Have you considered a sword that's a little smaller?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Hmm, I feel much better using a sword as large as this one."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Also, I feel as though I'll become stronger swinging around such a large sword."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "I see."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Regardless, thank you. I'll return again. I'll see you later too, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Yes."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Thanks for visiting."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "...Oww."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "What's wrong?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "I'm fine. It's just that my arm's really tired from carrying around Sir Julio's sword."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "You really would get stronger if you were always swinging that thing around."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "It's that heavy? Sir Julio is really amazing..."
        }
    ]
}