{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS01_200.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "That should do it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hello, Mrs. Marguerite."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Hello, Sophie. I'm sorry, but I've already closed the store for today."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "No, that's okay. I'll come back again tomorrow."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x24,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Sorry about that..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Still, you're always cleaning up for so long every day."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "If I leave things out, the vegetables will go bad. I can't sell bad produce to my customers."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Although, not everything lasts until the next day, no matter what I do."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "There are some things that will spoil regardless."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yeah..."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "It would be wasteful to throw it away, so we eat it here at home before it goes bad."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "How much is there?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "It's not too much. And even when we have lots of leftovers for many days in a row, Oskar eats it all."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Ahaha, I'd expect no less from Oskar."
        },
        {
            "type": 0x5,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "unknown2": 0x2,
            "msg_string": "Mom, is dinner ready yet?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Yeah, yeah, I'll be right there!"
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Anyway, have a good night, Sophie."
        }
    ]
}