    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Mrs. Marguerite, are you taking a break?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yes, I'm tired from working since early in the morning. I'm taking a short rest here."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Wouldn't it be better to rest inside?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "I would love to, but if I take my eyes off a certain someone, he'll slack off."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Ahaha, I can't deny that."
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "I'm thankful that he's helping, at least."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hey, Sophie. Welcome."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Wait, are you running the shop alone today? Where's Mrs. Marguerite?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Over there."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ah, she's on break."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Seriously, I'm tired from doing all this work alone..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "But she's always working. You need to help her more, got it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "You slack off whenever you get the chance, after all."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "I know, I know. But I can't help it if I'm tired..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Mom, could you switch with me already? I'm really tired!"
        },
        {
            "type": 0x2,
            "voice_id": 0x11b,
            "name_id": 0x10,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I guess I can't help it. I'll get back to work."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Ahaha, those two really get along."
        }
    ]
}