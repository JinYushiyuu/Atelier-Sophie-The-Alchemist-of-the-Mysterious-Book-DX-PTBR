        {
            "type": 0x2,
            "voice_id": 0xa,
            "name_id": 0xa,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yes. It was a garden built long ago, but it's just abandoned ruins now."
