        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Apparently, it's a palace that fell from the sky."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x3,
            "msg_string": "Whaaat!? From the sky? How is that even possible?"
