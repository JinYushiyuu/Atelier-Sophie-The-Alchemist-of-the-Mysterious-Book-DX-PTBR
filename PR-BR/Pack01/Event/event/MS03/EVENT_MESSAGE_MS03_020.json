{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS03_020.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "This is a weapon for Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Seeing how I made it, I know this is weird to ask, but... What is this?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Huh? It's a bracelet."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "I know it's a bracelet, but I don't understand how you would use this."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "How does a bracelet function as a weapon...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "U-um... Just a minute, I'll go call Plachta!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "This is a necessary device to control \"Hexe Auris\"."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "\"Hexe Auris\"...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "This."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "W-what's that!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x5f,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "This bracelet is required to control these arms."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "That's... Quite the amazing device. How does it work, anyway...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Using the power of alchemy. I'm surprised you were able to make this bracelet."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Creating this bracelet requires the power of alchemy, so I asked Sophie to make it for me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xe,
            "msg_string": "Wait, you did...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "S-sorry..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "However, the bracelet is functioning properly. It seems Logy has some aptitude for alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "I do...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "What do you think? If you're interested, would you like to try learning alchemy with Sophie?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "...I'm happy for the offer, but I'll pass. I really like the work I'm doing now."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I see. If you ever find yourself interested, come to Sophie's atelier. You'd be welcome anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Yeah, I'd welcome you too."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Haha, thanks."
        }
    ]
}