{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS03_050.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Haah... It's done, Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Logy, are you okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Yeah, I'm fine. But Sir Julio's sword is really heavy..."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Weight is an important factor for increasing power."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, hello Sir Julio."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hello, Sophie. I see you asked Logy to make me a sword. Thank you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Oh no, you're always helping me when I go gathering, it's the least I could do."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Still, I know you want more power, but is it really necessary to make a sword THIS large?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Wouldn't this slow down your movement and attack speed?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "No, having a large weapon allows one to confront multiple enemies alone at the same time."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Also, durability is more important than speed."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Durability...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "I see. It would be a huge problem if a knight's sword was to break."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "Exactly. I think I'll be able to improve my strength more with this, too."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Just be sure not to overdo it. If there's any problem, I'll fix it right away."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Thank you."
        }
    ]
}