{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS03_080.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Alright, these should work."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Then I'll go call Harol."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Bullets for my guns, huh?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "You showed me the guns before. I made these from my memory, what do you think?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Yeah, I think these would be fine..."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I see, that's good."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Still, I was never really concerned about the bullets I used up until now."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "It's important for the guns themselves to be well made, but the bullets you use can change their effectiveness as well."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "It's the same as any projectile weapon. You can change the ammunition you use to emphasize velocity, density, etc."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Interesting..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Huh, I didn't know they had different purposes."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "You use different items against different enemies too, right? It's similar to that."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I see... Now that you mention it..."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "If you modify your guns, come see me again. It's dangerous to use bullets that don't fit right."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yeah, thanks for that. I'll see you later."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Alright, these should work."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Then I'll go call Harol."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Hm, bullets...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "You showed me the guns before. I made these from my memory, but... What do you think?"
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "...Hmm, these are way higher quality than the ones sold on the market."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I see, that's good."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Still, bullets huh... I never really cared before about what I was firing, as long as it hit."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "The precision of the guns is important, but the quality of the bullets you fire can also affect your accuracy."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x17,
            "msg_string": "I see. Still, with bullets this good, I'm starting to want even better guns to go with them..."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "I'll try modifying my guns to go with these bullets."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x19,
            "msg_string": "Ahaha, sounds like you're having fun, Harol."
        },
        {
            "type": 0x2,
            "voice_id": 0x7,
            "name_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Hah... Anyway, see you later."
        }
    ]
}