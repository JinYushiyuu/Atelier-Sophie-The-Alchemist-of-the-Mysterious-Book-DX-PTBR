{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS03_040.ebm",
    "nb_messages": 0x13,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "It's done, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Thank you very much. I'll go call Oskar."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Yeah, this is good. Thanks, Logy."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm relieved. It's been a while since I made something other than a weapon. I was a little worried."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Huh? What are you talking about? This is my weapon."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Wait, but it's just a shovel?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Oskar's always fighting using a shovel..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "You can use this for all kinds of attacks, it's really convenient."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "But a normal weapon would be lighter, and it would have more damage potential too."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "That would mean I'd have to carry another weapon. I don't want to lug that around."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x2e,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "So you have to carry around a shovel..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xb,
            "msg_string": "It's useful for harvesting stuff, but I also need to fix the dirt that gets kicked around in battle for the plants."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "W-when were you doing that..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "It's a lot of work. It's especially bad when you decide to use your bombs, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "We can't just leave craters lying around."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "S-sorry..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Anyway, that's why I need a big shovel."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I'm pretty satisfied with this. See you later!"
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "Well, I guess it's fine as long as he's okay with it..."
        }
    ]
}