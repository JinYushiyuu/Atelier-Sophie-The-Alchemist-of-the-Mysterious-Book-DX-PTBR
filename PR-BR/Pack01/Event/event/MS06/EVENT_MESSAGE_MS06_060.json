{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MS06_060.ebm",
    "nb_messages": 0xd,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x0,
            "msg_string": "Hey, wait, wait. What exactly are you thinking?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "Huh? W-what are you talking about...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "That armor. It's all worn out and a total mess. I can't let this slide as a designer."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Uu, sorry..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "...If it's that worn out, it might be better just to remake it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "Remake it...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yeah. If you bring me the materials to use, I can fix it up like new... No, even better than new."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Well, remaking it would mean it won't go back to the original, but... I don't think that's something to worry about."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "You can do something like that...? That's amazing, Leon!"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sure. Just let me know when you're up for it."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can now use \"Armor Enhancement\" at Leon's shop."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "You can enhance your armor's stats by applying (Cloth) category items to it."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "The number of times armor can be enhanced varies, and the stats enhanced depends on quality and traits."
        }
    ]
}