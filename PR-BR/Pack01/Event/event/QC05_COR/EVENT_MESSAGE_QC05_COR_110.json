        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "But this is similar to a general store, so I'm thinking about selling all kinds of items."
