{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_COR_210.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Cory, what are you doing here?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x5a,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Oh, Sophie..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Ahh, you're listening to the music box. You really do like that music box, don't you?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x5a,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Yes... I like it very much. It's like my treasure now..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "A treasure, huh...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x5,
            "msg_string": "I started all this to find my dad, but... Lately, I've been feeling like this is more important."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x18,
            "expr_id": 0x2,
            "msg_id": 0x6,
            "msg_string": "I don't really care about finding my dad anymore."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "What!? R-really? Is that really okay!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x8,
            "msg_string": "...I'm joking."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "I still want to meet my dad."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Okay, that's good... It's too hard to tell when you're joking, Cory..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "...I'm sorry. But it's also true that I cherish this music box..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "I was able to obtain a treasure like this because I opened my store... And because I met you."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "That's why I'm glad I opened my duplication store."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0xe,
            "msg_string": "Ehehe. I'm glad I met you too, Cory!"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Yes. I hope to keep seeing you, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Yeah, me too! This is just the beginning!"
        }
    ]
}