{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC05_COR_100.ebm",
    "nb_messages": 0x19,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Hmm..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "What's wrong, Cory? Thinking about something again?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Yes... It's about my store..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'd be willing to listen, if it's okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "... I want..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "You want?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x6,
            "msg_string": "...I want to make this store more famous. How can I do that?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Huh? More famous...? Um... That's... Hmm."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "It really is difficult."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Y-you're right... If I knew that, I wouldn't have any problems with my store, either. Ahaha..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "I'm working hard every day, but as you can see, I can hardly sell anything."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "You aren't selling much? It's true that I barely see any customers in here."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Yes, I can't sell much at all. I might even go out of business at this rate..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "Wait, really!? That's bad, what can we do?"
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "I'm selling a little bit, so it's not so bad that I need to close the store yet."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Oh, don't scare me like that."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "...But it's true that I hardly sell anything."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "If you buy a mountain of merchandise, I'm sure this store would grow big and popular..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x12,
            "msg_string": "I-I can't afford that. I do want to help, though..."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I told you before, but the main problem is that this store caters to a narrow range of people..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "That's not really something I can help with."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Yes, that's why I'm so concerned."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Nothing will change if I just keep worrying, though. I'll just keep trying to work."
        },
        {
            "type": 0x2,
            "voice_id": 0x6,
            "name_id": 0x6,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Please buy lots of things from me, too."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "Y-yeah, ahaha..."
        }
    ]
}