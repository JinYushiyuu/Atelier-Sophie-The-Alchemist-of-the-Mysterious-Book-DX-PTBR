{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_LEO_010.ebm",
    "nb_messages": 0x1b,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0xffffffff,
            "msg_id": 0x0,
            "msg_string": "(Huh, who's that? I've never seen her before... What's she doing...?)"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x25,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Yeah, this place has pretty good atmosphere. Not bad at all."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "msg_string": "(She's looking at... The church? Could she be a traveler?)"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2e,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "(...Still, she's wearing really pretty clothes. I want to try wearing clothes like that too...)"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x25,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "...Hey, you there."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0x5,
            "msg_string": "Me!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x25,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "It looked like you were staring at me... Why?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Oh, um, I... I just thought you were wearing really pretty clothes..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x25,
            "extra_id": 0x6a,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Oh really? That's good."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x25,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "...Do you live in this town?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ah, yes I do. I'm Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Sophie, huh? I'm... You know what, you can just call me Leon."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Leon...? Um, are you a traveler?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Pretty much. I travel to lots of places, tailoring and selling clothes."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Huh, so you're a clothier? No wonder you're wearing such lovely clothes."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hehe, I'm happy you feel that way."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Hey, Sophie. There's something I want to ask you..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "What is it?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "...What's that church called?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "That's the Varum Church. It's a tourist attraction here in Kirchen Bell."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2b,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Hmm... The Varum Church, huh... Not a bad name."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2d,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "It looks similar to the church in my hometown. It made me feel a little nostalgic."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "I see."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "...Alright, I've made my decision."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "I'm going to stay in this town for a while. I like the church here, and the air's clean and refreshing."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "It's nice to meet you, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Yeah, same here!"
        }
    ]
}