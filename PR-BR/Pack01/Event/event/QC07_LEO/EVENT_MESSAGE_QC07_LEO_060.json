{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_LEO_060.ebm",
    "nb_messages": 0x17,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "*Sigh*..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1,
            "msg_string": "Is something wrong? You look like you're spacing out."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, I was just thinking about how pretty your clothes are, Leon..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "That's all?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "That should be obvious. They're clothes that I made, after all."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Wow, you're really confident..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x6a,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Of course I am. You can't run a shop if you don't have confidence in your own goods."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "You make use of all of your skills to create the best goods possible for your customers."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's the pride of an artisan."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Leon... You're so cool...!"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0xa,
            "msg_string": "Oh... Really? Well, it's not a bad feeling when you say that."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Yeah. Who exactly are you, anyway?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Huh!? W-what do you mean by that?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "I mean, you're able to make way prettier clothes than any other shop in town..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2e,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Are you actually a really famous or amazing person, Leon?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "An amazing person, huh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I don't know what qualifies someone to be called \"amazing\", but I'm myself."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "I'm just the wandering beauty and clothier, Leon. Nothing more, nothing less."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x12,
            "msg_string": "Ahaha. You just called yourself a beauty."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "...What's so wrong about that? I'm pretty confident in my looks."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I never said it was wrong. I think you're really beautiful too."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Oh? That's good, then."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Anyway, enough talk about me. Feel free to come visit my shop anytime."
        }
    ]
}