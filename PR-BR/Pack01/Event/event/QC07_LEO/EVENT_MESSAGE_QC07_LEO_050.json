        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x10,
            "msg_string": "Ahahahaha, alchemy sure is profound! I really like it!"
