            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x11,
            "msg_string": "Anyway, I'll see you again, Sophie! Thanks for today, I really mean it! Heh heh heh..."
