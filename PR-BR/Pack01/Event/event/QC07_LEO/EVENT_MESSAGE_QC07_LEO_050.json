        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Yes, I'm sorry for the late introduction. My name is Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Huh, so your name's Plachta. A talking book, that's pretty amazing! I'm amused!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "H-huh...? She's not shocked...!? In fact, she's having fun?"
