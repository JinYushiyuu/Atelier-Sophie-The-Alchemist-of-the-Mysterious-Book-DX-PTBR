        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x7,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Hehe, I got to see something great today. Anyway... I should get going soon."
