        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x20,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "...Hey. That book just talked, didn't it?"
