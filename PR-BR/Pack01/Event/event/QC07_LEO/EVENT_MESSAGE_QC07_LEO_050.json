            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Hey, Plachta! You're going to startle her, you can't just pop out like that..."
