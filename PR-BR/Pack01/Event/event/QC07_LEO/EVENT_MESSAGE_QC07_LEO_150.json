            "voice_id": 0xc1,
            "name_id": 0x1e,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x2,
            "msg_string": "Yeah, her. I heard that she disappeared right after winning the contest..."
