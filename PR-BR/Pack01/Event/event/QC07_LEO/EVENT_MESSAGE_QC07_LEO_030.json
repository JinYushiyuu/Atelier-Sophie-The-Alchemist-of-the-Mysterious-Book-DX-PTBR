            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x193c,
            "msg_string": "I've already got my first customer... I should just open shop right now."
