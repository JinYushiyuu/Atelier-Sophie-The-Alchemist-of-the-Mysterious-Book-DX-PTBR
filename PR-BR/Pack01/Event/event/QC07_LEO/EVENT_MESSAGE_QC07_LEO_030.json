            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x1934,
            "msg_string": "With this much, I won't have to worry about cloth for a while."
