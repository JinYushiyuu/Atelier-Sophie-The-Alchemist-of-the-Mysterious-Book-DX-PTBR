            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x1936,
            "msg_string": "Looks like it was the right choice to leave it to you. Thanks, this is your payment."
