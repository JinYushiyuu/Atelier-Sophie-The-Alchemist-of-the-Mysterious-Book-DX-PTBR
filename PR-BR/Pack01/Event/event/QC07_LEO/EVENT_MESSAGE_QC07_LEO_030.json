            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0x1940,
            "msg_string": "Yup. You did all this work so that I could open my shop, after all."
