        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Received 1000 Cole."
