{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC07_LEO_230.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Wow! It's amazing! It's so pretty! Ahahahaha!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Sophie, it's dangerous to run around carelessly."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Now then... This spot should be good. How about we get dressed for our vacation?"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x2,
            "msg_string": "Ahahahaha, this is fun! You should come over here too, Plachta!"
        },
        {
            "type": 0x5,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x2,
            "msg_string": "Hehe, she's calling for you. Are you sure you shouldn't go?"
        },
        {
            "type": 0x5,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x2,
            "msg_string": "Yes. Sophie's stamina is always endless during times like this. I'd just get tired trying to keep up with her."
        },
        {
            "type": 0x5,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x2,
            "msg_string": "Also, I'm still reluctant to get wet..."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x2,
            "msg_string": "Take that!"
        },
        {
            "type": 0x5,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "unknown2": 0x2,
            "msg_string": "Aaah!? S-stop that, Sophie! Don't splash water onto me!"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "unknown2": 0x2,
            "msg_string": "Haha, no way. I won't stop until you come over here."
        },
        {
            "type": 0x5,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xa,
            "unknown2": 0x2,
            "msg_string": "Sophie! I'll get mad if you don't behave yourself! Hey, Sophie!?"
        },
        {
            "type": 0x5,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "unknown2": 0x2,
            "msg_string": "You two really get along."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Ahh, that was fun! Leon, thank you so much for inviting us!"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Uu... My clothes are all wet... I feel so uncomfortable..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "I'm glad you had fun."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xf,
            "msg_string": "Hey, both of you. This won't be for a while, but... I'm thinking about leaving this town."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "...This is sudden. Why?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "...Because I remembered what I really wanted to do."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Oh... You mean your real dream, the one you talked about before...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Yeah. I can't just stay here forever. So I'm not going to be \"Leon\" for much longer."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I need to go back to being \"Amelia\", and make clothes that really put smiles on people's faces."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "I can understand that... But if you left, I would..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Hehe, don't make a face like that. I made those clothes for you while thinking about your smile."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "They look best while you're smiling. So you need to always keep that bright smile, okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "Leon..."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Also, I said it wouldn't be for a while. I plan to relax here for a little longer."
        },
        {
            "type": 0x2,
            "voice_id": 0x8,
            "name_id": 0x8,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "So... I'd be happy if we got along while I'm still here in town."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "...Yeah, I promise!"
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Leon learned the skill \"<CLGR>Aggressive Sense<CLNR>\"."
        }
    ]
}