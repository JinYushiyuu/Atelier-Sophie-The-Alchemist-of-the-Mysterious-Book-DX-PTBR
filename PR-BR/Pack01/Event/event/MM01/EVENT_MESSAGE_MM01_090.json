{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_090.ebm",
    "nb_messages": 0x14,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x45,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Certo! Não vamos perder tempo. Pode me ensinar algumas coisas, Plachta?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "Você está bastante entusiasmada."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x46,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sim! Não quero ser uma novata para sempre!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "msg_string": "Hehe... Muito bem, tente Sintetizar algo primeiro."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x47,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Síntese? Isso eu sei fazer!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Vamos ver, materiais, materiais... Oh."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "O que foi?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x25,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Usei todos os meus materiais quando fiz aquele Remédio Berg... Não sobrou nada."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "Então parece que você precisa coletar alguns. Há algum lugar próximo onde possa fazer isso?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sim, conheço um lugar, mas... Puni aparecem lá, então tenho medo de ir sozinha..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Ah, certo. Posso pedir para a Monika vir comigo."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "Monika? É aquela garota que estava com você ontem?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x40,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Sim. Na verdade, ela é bem forte!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "Entendo, então você deve estar segura. Muito bem, por favor, tome cuidado."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Hã? Você não vem também?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "Como pode ver, mesmo que eu fosse, não conseguiria lutar. Já que sou um livro, afinal."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ah, é mesmo. Certo, vou indo então!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "msg_string": "Sim. Tente voltar rápido. O tempo é finito, afinal."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "Se demorar muito, não terei tanto tempo para lhe ensinar alquimia."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x13,
            "msg_string": "Ahaha, você tem razão. Certo, vou tentar voltar depressa!"
        }
    ]
}