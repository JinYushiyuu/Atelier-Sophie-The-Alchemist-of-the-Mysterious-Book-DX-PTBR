{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_170.ebm",
    "nb_messages": 0x26,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Voltamos!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "msg_string": "Ah, bem-vinda de volta. Isso demorou muito."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x2,
            "msg_string": "E-esse livro está flutuando!? E falando!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2f,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Nunca pensei que ouviria as vozes de livros além das plantas..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x29,
            "expr_id": 0x3,
            "msg_id": 0x4,
            "msg_string": "N-não, Oskar, não é só você. Eu também consigo ouvir, desta vez..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "Sophie, parece que seus amigos são tão barulhentos quanto você."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Ahaha... Tenho certeza de que qualquer um ficaria surpreso se visse você, Plachta..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Hum... Vocês dois, esta é..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Você escreveu algo em um livro de referência, e ele começou a falar? Parece mais um sonho."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Nunca pensei que aquele livro acabaria sendo algo tão incrível..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Eu também fiquei chocada no começo. Quer dizer, um livro estava voando e falando, afinal."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "Não acho que seja tão chocante..."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Não, é sim..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "Então hum... Senhorita Plachta?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xe,
            "msg_string": "Pode me chamar de Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Ah, certo então, Plachta... O que, ou quem é você?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Ah, eu fiz a mesma pergunta. Mas parece que a Plachta não tem nenhuma memória."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Sério?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "Sim. As únicas coisas que sei são meu nome, e um pouco de conhecimento de alquimia."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Certo. É por isso que quero descobrir um jeito de recuperar as memórias dela."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Memórias, hein... Talvez elas voltem se você encontrar algum tipo de pista?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x15,
            "msg_string": "Uma pista... Hmm..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Ah, Sophie. Acabei de pensar em uma coisa!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x17,
            "msg_string": "A Plachta começou a falar porque você escreveu algo no livro, certo?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x18,
            "msg_string": "Sim, acho que foi isso."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Então talvez as memórias dela voltem se você escrever mais receitas no livro?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x1a,
            "msg_string": "Uau, isso faz sentido! Você é bem esperta, Monika!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "O que você acha, Plachta?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1c,
            "msg_string": "Não parece absurdo. Acho que valeria a pena tentar."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x49,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Certo, nesse caso, vou estudar muita alquimia, e escrever muitas receitas em você!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Sinto que algum tipo de destino nos trouxe aqui. Se houver algo em que eu possa ajudar, me avise."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Sim, vou ajudar no que puder também."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x20,
            "msg_string": "Obrigada aos dois!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Ei, está ficando tarde. Preciso ir para casa ou minha mãe vai me dar bronca de novo."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x22,
            "msg_string": "Vou indo também. Até mais, Sophie e Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x23,
            "msg_string": "Sim, até mais!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x24,
            "msg_string": "Preciso me esforçar, pela Plachta!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "msg_string": "Sim, tenho grandes esperanças, Sophie."
        }
    ]
}