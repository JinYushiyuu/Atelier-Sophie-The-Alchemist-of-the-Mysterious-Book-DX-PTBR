{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_070.ebm",
    "nb_messages": 0x20,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x49,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Alright, done! Monika, it's ready!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "Hm... That's amazing, it really is Berg Medicine..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x28,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Thank you, Sophie. You really helped me out."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Don't worry about it. We're friends, right?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hehe, right. Anyway, I'll take this over to Mr. Horst now."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "...Hey Monika. Do you mind if I go along?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Huh? I don't mind... But why?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "I'm the one who made this medicine. If it turned out to be no good, it would mean trouble..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Hmm, I think it's fine, but... Well, it couldn't hurt. Let's go."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Yeah... Oh, just a minute!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I should write the recipe into the reference book, while it's still fresh in my mind."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Sorry for the wait, Monika. Anyway, let's go see Mr. Horst!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Mr. Horst!"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Ah, you two. Do you need anything?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Mr. Horst. I've brought the Berg Medicine you requested."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Oh, thank you very much for bringing it so quickly, Monika."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Well... Actually, Sophie made it. I couldn't find any Berg Medicine myself..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Sophie, you made this?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yes. Um... Is there something wrong with it?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Not at all! In fact, it's quite rare to see Berg Medicine as fine as this!"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "It seems your skills with alchemy are improving quite a bit, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Ehehe..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "You two have been very helpful. Here's your payment."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Received 200 Cole."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "Wow, thank you so much, Mr. Horst!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "Um... I didn't really do anything. I can't accept this..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "No, no, I'm the one who made such a sudden request. Think of it as a payment for your time, I insist."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "...Very well, I'll accept it gratefully."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Thank you too, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "If you're ever troubled by anything, just ask. I'll do whatever I can to help."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "Anyway, I'll get going now. Have a good day Mr. Horst, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Yes, have a good day."
        }
    ]
}