{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_070.ebm",
    "nb_messages": 0x20,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x49,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Certo, pronto! Monika, está pronto!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "Hm... Isso é incrível, é realmente Remédio Berg..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x28,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Obrigada, Sophie. Você me ajudou muito."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Não se preocupe. Somos amigas, certo?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Hehe, certo. De qualquer forma, vou levar isso ao Sr. Horst agora."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "...Ei Monika. Você se importa se eu for junto?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Hã? Não me importo... Mas por quê?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Fui eu que fiz esse remédio. Se não ficar bom, pode dar problema..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Hmm, acho que está bem, mas... Bem, não custa nada. Vamos."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Sim... Ah, só um minuto!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Devo escrever a receita no livro de referência, enquanto ainda está fresca na memória."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Desculpe a demora, Monika. De qualquer forma, vamos ver o Sr. Horst!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Sr. Horst!"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Ah, vocês duas. Precisam de algo?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Sr. Horst. Trouxe o Remédio Berg que o senhor pediu."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3e,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Oh, muito obrigado por trazer tão rápido, Monika."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Bem... Na verdade, a Sophie que fez. Eu não consegui encontrar nenhum Remédio Berg..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Sophie, você fez isso?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Sim. Hum... Tem algo errado com ele?"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "De forma alguma! Na verdade, é muito raro ver um Remédio Berg tão bom quanto este!"
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Parece que suas habilidades com alquimia estão melhorando bastante, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4e,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Ehehe..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Vocês duas foram muito úteis. Aqui está o pagamento."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Recebeu 200 Cole."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x18,
            "msg_string": "Uau, muito obrigada, Sr. Horst!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "Hum... Eu não fiz nada, na verdade. Não posso aceitar isso..."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "Não, não, fui eu que fiz um pedido tão repentino. Considere como um pagamento pelo seu tempo, eu insisto."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x1b,
            "msg_string": "...Muito bem, aceitarei com gratidão."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Obrigada a você também, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1d,
            "msg_string": "Se algum dia tiver problemas com qualquer coisa, é só pedir. Farei o que puder para ajudar."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x1e,
            "msg_string": "De qualquer forma, vou indo agora. Tenha um bom dia, Sr. Horst, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0xd,
            "name_id": 0xd,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1f,
            "msg_string": "Sim, tenha um bom dia."
        }
    ]
}