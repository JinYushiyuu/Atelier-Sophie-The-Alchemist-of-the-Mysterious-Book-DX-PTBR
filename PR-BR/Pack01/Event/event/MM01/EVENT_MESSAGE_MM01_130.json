{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_130.ebm",
    "nb_messages": 0x11,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x22,
            "expr_id": 0x4,
            "msg_id": 0x0,
            "msg_string": "Haah, haah... E-Eu pensei que fosse morrer..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Vocês dois parecem ilesos."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Sim, de alguma forma... Não achei que eles atacariam tão de repente assim..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Ei, Oskar. Você quer vir conosco? É perigoso ficar sozinho, monstros podem atacar de novo."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Você provavelmente está certo. Tudo bem, vou com vocês. Afinal, não quero me machucar."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Nesse caso, vamos começar a coleta. Ah, você precisa ajudar também, Oskar."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x6b,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "O quê!? Eu nunca disse que faria isso..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Não contaremos para a Sra. Marguerite que vimos você aqui. Tudo bem?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Uu, tudo bem, entendi..."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "\"<CLGR>Oskar<CLNR>\" entrou no seu grupo."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Gostaria de ver a explicação sobre Pontos de Coleta e Símbolos de Inimigos?"
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Pressionar <IM00> perto de um Ponto de Coleta no campo permitirá que você colete itens."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "No entanto, monstros também habitam na maioria das áreas."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Tocar em um símbolo de inimigo iniciará uma batalha."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Se você acertar o inimigo balançando seu cajado primeiro, começará a batalha com vantagem."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode Balançar pressionando <IM04>. Faça bom uso disso."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode ver mais detalhes sobre Pontos de Coleta e Símbolos de Inimigos em Ajuda na Enciclopédia."
        }
    ]
}