{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_120.ebm",
    "nb_messages": 0x25,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x0,
            "msg_string": "Ahh, o ar fresco é ótimo. Sinto que não saio da cidade há muito tempo."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x20,
            "expr_id": 0x3,
            "msg_id": 0x1,
            "msg_string": "Sophie, você precisa tomar mais cuidado. Não temos ideia de quando monstros podem aparecer."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0x2,
            "msg_string": "Eu sei... Espere? Tem alguém ali...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Aquele é... Heeey, Oskar!"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Oh, Sophie e Monika. O que vocês estão fazendo aqui?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Estamos aqui para coletar materiais de alquimia. E você?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Vim observar as plantas. As plantas daqui contam histórias interessantes."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x43,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Oskar, não me diga que você estava falando com plantas de novo?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "Exatamente o que eu estava fazendo. O que há de estranho nisso? Para mim, é mais estranho não conseguir falar com plantas."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "...Sim, você sempre foi assim. Não pretendo discutir depois de tanto tempo."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x5,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Isso soou vagamente como um insulto..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Ah, sim. Oskar, a Sra. Marguerite estava procurando por você."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xc,
            "msg_string": "Gah, droga! Esqueci completamente da minha entrega! Minha mãe vai me dar uma bronca!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "A culpa é sua. Apenas aceite, Oskar."
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Huh, que som foi esse?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0xf,
            "msg_string": "Eeek! Puni!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x10,
            "msg_string": "Sophie, fique atrás! Oskar, você sabe lutar, certo?"
        },
        {
            "type": 0x2,
            "voice_id": 0x3,
            "name_id": 0x3,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x11,
            "msg_string": "O-o quê!? E-espere um segundo! Não estou preparado para isso..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x12,
            "msg_string": "Lá vêm eles!"
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Gostaria de ver a explicação sobre batalhas?"
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Na batalha, inimigos e aliados se revezarão realizando ações."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Uma vez determinadas as ações inimigas, você poderá selecionar ações para o seu grupo."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode usar comandos para várias ações. Selecione com <IM10> e pressione <IM00> para confirmar."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "A ordem de ação é exibida à esquerda, e segue na ordem de cima para baixo."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "A ordem pode mudar frequentemente, dependendo das ações realizadas."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Além disso, um fator importante na batalha é a \"Postura\"."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Existem dois tipos de Posturas, \"Ofensiva\" e \"Defensiva\"."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "A \"Postura\" pode ser alterada a qualquer momento durante a seleção de comandos pressionando <IM11><IM15>, com diferentes benefícios."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Escolher \"Ofensiva\" aumentará seu poder de ataque."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Também permite realizar \"Ataques de Suporte\", seguindo com ataques adicionais de outros aliados."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Escolher \"Defensiva\" aumentará sua defesa."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Também permite usar \"Guarda de Suporte\", permitindo que os aliados protejam uns aos outros quando atacados por inimigos."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Cada ação de suporte será usada automaticamente quando a barra de Elo de Corrente estiver cheia em 100%."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "O tipo de ação de suporte é determinado pela sua Postura atual."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode obter vantagem na batalha verificando as ações inimigas e escolhendo a Postura adequada."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Faça bom uso das informações exibidas na lista de turnos."
        },
        {
            "type": 0x3,
            "voice_id": 0xffffffff,
            "name_id": 0x26,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0xffffffff,
            "msg_string": "Você pode ver mais detalhes sobre batalha em Ajuda na Enciclopédia."
        }
    ]
}