{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_015.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Now, back to work."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "I need to put in the Puniball, and then add the Uni after boiling it for a little while..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xf,
            "msg_id": 0x2,
            "msg_string": "Yeah, this is going well... Now I just have to mix it a little and..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xf,
            "msg_id": 0x3,
            "msg_string": "...Huh? This is weird. What's with this color!? ...Eww, it stinks! Oh no, wait-...!"
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "This is Kirchen Bell... A small town brimming with greenery and the sounds of church bells."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "A certain girl lives alone in this town."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "Her name is Sophie."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "Here, she runs an atelier, using the alchemy she learned from her late grandmother."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "Although she still has quite a lot of room for improvement..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Uu, I messed up again..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x51,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "*Sigh*... At this rate, I'll never be as good as grandma was..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Aaah, if only there was a way to suddenly get really good at alchemy."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Then I could make amazing medicine and stuff, and everyone in town would rely on me... Ehehe."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "...I wouldn't have any problems if that was the case. *Sigh*... Guess I should clean up."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Oh, yes! It's open!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Hello, Sophie... What's that smell?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Ahaha... I messed up again..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "More importantly, why are you here Monika? Do you need something?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Yes. There's something I'd like to ask of you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Huh, it's unusual for you to have a request. What do you need?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "I just met with Mr. Horst. He was asking for some Berg Medicine, but..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "I've gone to every shop, and I can't find it anywhere. So I thought you might know something."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "You know, you're kind of an alchemist, right? That's why I'm asking..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x17,
            "msg_string": "I'm not \"kind of\" one!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x18,
            "msg_string": "But Berg Medicine, huh... I've never tried making that..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "I saw grandma making it before, so I should be able to make it too..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "It's a request I decided to accept. You don't have to force yourself if it'll be difficult."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "No, it's fine! I can't just ignore someone in need! Leave it all to me!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Oh, but... I'm still not confident about it, so I should look for grandma's book."
        }
    ]
}