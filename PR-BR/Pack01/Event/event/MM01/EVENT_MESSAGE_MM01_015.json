{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_015.ebm",
    "nb_messages": 0x1d,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Agora, de volta ao trabalho."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Preciso colocar a Puniball, e então adicionar a Uni depois de fervê-la um pouco..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xf,
            "msg_id": 0x2,
            "msg_string": "Sim, isto está indo bem... Agora só preciso misturar um pouco e..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0xf,
            "msg_id": 0x3,
            "msg_string": "...Hã? Isto é estranho. Que cor é essa!? ...Eca, está fedendo! Ah não, espera-...!"
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "msg_string": "Esta é Kirchen Bell... Uma pequena cidade repleta de verde e dos sons dos sinos da igreja."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "msg_string": "Uma certa garota mora sozinha nesta cidade."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "msg_string": "O nome dela é Sophie."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "msg_string": "Aqui, ela administra um ateliê, usando a alquimia que aprendeu com sua falecida avó."
        },
        {
            "type": 0x3,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x8,
            "msg_string": "Embora ela ainda tenha bastante espaço para melhorar..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x50,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Uu, eu errei de novo..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x51,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "*Suspiro*... Nesse ritmo, nunca serei tão boa quanto a vovó era..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x52,
            "expr_id": 0x4,
            "msg_id": 0xb,
            "msg_string": "Aaah, se ao menos houvesse um jeito de de repente ficar muito boa em alquimia."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0xc,
            "msg_string": "Aí eu poderia fazer remédios incríveis e tal, e todos na cidade dependeriam de mim... Ehehe."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x19,
            "expr_id": 0x2,
            "msg_id": 0xd,
            "msg_string": "...Eu não teria problemas se fosse o caso. *Suspiro*... Acho que devo limpar."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Ah, sim! Está aberto!"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Olá, Sophie... Que cheiro é esse?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "Ahaha... Eu errei de novo..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x11,
            "msg_string": "Mais importante, por que você está aqui Monika? Precisa de algo?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Sim. Há algo que eu gostaria de pedir a você."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Hã, é incomum você ter um pedido. Do que você precisa?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Acabei de me encontrar com o Sr. Horst. Ele estava pedindo um pouco de Remédio Berg, mas..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Fui a todas as lojas, e não consigo encontrar em lugar nenhum. Então pensei que você poderia saber de algo."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x16,
            "msg_string": "Sabe, você é meio que uma alquimista, né? É por isso que estou perguntando..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x17,
            "msg_string": "Eu não sou \"meio que\" uma!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x18,
            "msg_string": "Mas Remédio Berg, hein... Nunca tentei fazer isso..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x19,
            "msg_string": "Eu vi a vovó fazendo antes, então devo conseguir fazer também..."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x1a,
            "msg_string": "É um pedido que eu decidi aceitar. Você não precisa se forçar se for difícil."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "Não, tudo bem! Não posso simplesmente ignorar alguém precisando! Deixe tudo comigo!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1c,
            "msg_string": "Ah, mas... Ainda não estou confiante nisso, então devo procurar o livro da vovó."
        }
    ]
}