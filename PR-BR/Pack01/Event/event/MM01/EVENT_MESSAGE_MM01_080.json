{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_MM01_080.ebm",
    "nb_messages": 0x31,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Ufa, trabalhei duro hoje... Hã?"
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x1,
            "unknown2": 0x2,
            "msg_string": "O quêêêêêêê!? Aquele livro está flutuando!? E-Eu não sabia que livros podiam fazer isso!"
        },
        {
            "type": 0x5,
            "voice_id": 0x116,
            "name_id": 0x25,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x2,
            "unknown2": 0x2,
            "msg_string": "...Você acabou de chegar em casa, e já está fazendo tanto barulho."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x3,
            "unknown2": 0x2,
            "msg_string": "Oh, desculpe! ...Espere, o quê? O livro acabou de... falar?"
        },
        {
            "type": 0x5,
            "voice_id": 0x116,
            "name_id": 0x25,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x4,
            "unknown2": 0x2,
            "msg_string": "Sim, eu falei."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x5,
            "unknown2": 0x2,
            "msg_string": "O quêêêêêê!? O livro...! O livro está falando!?"
        },
        {
            "type": 0x5,
            "voice_id": 0x116,
            "name_id": 0x25,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x6,
            "unknown2": 0x2,
            "msg_string": "Por favor, acalme-se. As pessoas conseguem falar. Não é estranho um livro falar também."
        },
        {
            "type": 0x5,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0xffffffff,
            "expr_id": 0xffffffff,
            "msg_id": 0x7,
            "unknown2": 0x2,
            "msg_string": "Hã? H-hum, acho que não é assim que funciona..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "Hum... Então você é aquele livro de referência de antes, certo? Aquele em que eu escrevi."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x9,
            "msg_string": "Sim. Sou Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "Ah, você tem um nome... Sou Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xb,
            "msg_string": "Sophie? Vou me lembrar disso."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Hum... Senhorita Plachta?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xd,
            "msg_string": "Pode me chamar de Plachta."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x40,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Uh, certo. Hum, Plachta... O que exatamente você é?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "Um livro."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x35,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Isso eu vejo, mas... Você é um livro, e ainda assim está voando e falando... É muito estranho..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x11,
            "msg_string": "É verdade que sou diferente de um livro comum. Isso porque eu..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x12,
            "msg_string": "Eu... Isso é estranho, não consigo me lembrar. O que exatamente eu sou?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Hum, é isso que eu quero saber..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x14,
            "msg_string": "Espere, Plachta... Você não tem nenhuma memória?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x15,
            "msg_string": "Parece que sim. Mas eu me lembro que estou relacionada à alquimia."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1b,
            "expr_id": 0x2,
            "msg_id": 0x16,
            "msg_string": "Alquimia!? Então talvez eu possa ajudar! Na verdade, sou alquimista!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x17,
            "msg_string": "Sim, eu sei. Uma alquimista novata que nem sabe como produzir Remédio Berg."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x18,
            "msg_string": "Uu, então você viu isso... M-mas, eu consigo fazer agora..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x19,
            "msg_string": "Até uma criança poderia fazer isso se estudasse um pouco."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x27,
            "expr_id": 0x3,
            "msg_id": 0x1a,
            "msg_string": "Gah! M-mas, mas! O Sr. Horst me elogiou por isso, dizendo que estava muito bem feito!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1b,
            "msg_string": "Do meu ponto de vista, não pareceu particularmente excelente de forma alguma."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x28,
            "expr_id": 0x3,
            "msg_id": 0x1c,
            "msg_string": "... Sim, sou terrível em alquimia. Cometo muitos erros, e não consigo fazer muitas coisas."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x21,
            "expr_id": 0x4,
            "msg_id": 0x1d,
            "msg_string": "Não consigo ajudar as pessoas da cidade como minha avó conseguia..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x1e,
            "msg_string": "...Você deseja se tornar melhor?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x23,
            "expr_id": 0x4,
            "msg_id": 0x1f,
            "msg_string": "...Hã?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x20,
            "msg_string": "Estou perguntando se você deseja se tornar melhor em alquimia."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x21,
            "msg_string": "Claro que sim. Eu faria, se pudesse..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x22,
            "msg_string": "Existe um dispositivo chamado \"Caldeirão do Conhecimento\". Ele permite que qualquer pessoa use o poder da alquimia."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x23,
            "msg_string": "Com ele, você seria capaz de usar livremente a alquimia, como deseja."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x24,
            "msg_string": "Existe um dispositivo incrível assim!? Eu quero! Onde posso encontrá-lo!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x25,
            "msg_string": "O \"Caldeirão do Conhecimento\" é... Isso é estranho."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0x26,
            "msg_string": "...Ah não, não me diga... Plachta, você esqueceu onde está o Caldeirão?"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x27,
            "msg_string": "...Parece que sim."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x26,
            "expr_id": 0x3,
            "msg_id": 0x28,
            "msg_string": "O quêêêêêê!? Você está falando sério!?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x29,
            "expr_id": 0x3,
            "msg_id": 0x29,
            "msg_string": "Isso é terrível! Você me encheu de esperança, só para destruí-las!"
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x2a,
            "msg_string": "...Sinto muito. Mas não consigo me lembrar de nada."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x2b,
            "msg_string": "...Como compensação, posso eu mesma lhe ensinar alquimia."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x2c,
            "msg_string": "Posso ter perdido minhas memórias, mas estou confiante de que meu conhecimento de alquimia excede o seu."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x2d,
            "msg_string": "Hmm, você parece bem inteligente, e provavelmente sabe mais sobre alquimia do que eu..."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x2e,
            "msg_string": "Se você me ensinar, aceitarei com prazer..."
        },
        {
            "type": 0x2,
            "voice_id": 0x116,
            "name_id": 0x1,
            "expr_id": 0xffffffff,
            "msg_id": 0x2f,
            "msg_string": "Muito bem. Trabalharemos juntas a partir de agora, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x30,
            "msg_string": "Sim! Estou ansiosa por isso, Plachta!"
        }
    ]
}