        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Wow... You're really cool, Sir Julio..."
