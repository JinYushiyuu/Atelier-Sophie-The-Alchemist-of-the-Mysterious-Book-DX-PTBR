            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "It's unusual to see you at Mr. Horst's shop."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "That's not true, I actually come here quite often."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Really?"
