            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x17,
            "expr_id": 0x2,
            "msg_id": 0x7,
            "msg_string": "Hahaha, I'm not taking up requests that are overly difficult. There's no need to worry."
