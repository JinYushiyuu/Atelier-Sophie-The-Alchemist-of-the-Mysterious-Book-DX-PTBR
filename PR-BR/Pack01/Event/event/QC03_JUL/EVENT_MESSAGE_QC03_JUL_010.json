    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Sir Julio."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hello, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "What are you doing here?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "I'm a knight affiliated with the Church. One of my jobs is to guard churches."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I didn't know that."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "...Wait? Then is it really okay for you to leave town with us?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Yes, there's no need to worry. There's someone else who guards the church here as well."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Besides, leaving the town with you allows me to survey the area."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x44,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That's also part of my duties, so there's no issue at all."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Ah, that's good."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "I usually spend my time guarding the church, so if you need anything from me, come here."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I'll lend you my strength wherever possible."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Okay, I will. Thank you."
        }
    ]
}