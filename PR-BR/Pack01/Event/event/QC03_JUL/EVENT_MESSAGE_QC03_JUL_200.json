    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "I see you made a large amount. Thank you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "No problem."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Did you find anything about this place?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Yes, it seems this was a base for traveling to another world."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Another world...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x5,
            "msg_string": "The entrance will appear if you fulfill certain conditions. It seems to be related to time..."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "However, I couldn't decipher the details. I seem to be missing some information."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x36,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I see..."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2e,
            "expr_id": 0x4,
            "msg_id": 0x8,
            "msg_string": "It seems there are still many mysteries waiting to be found in this world."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "By the way, what is that? I didn't see it last time we came here..."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "It seems to be the entrance to another world."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xb,
            "msg_string": "What? That thing is?"
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2f,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "I can feel some sort of mysterious power from it."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "If you're going to go, you should be careful."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xe,
            "msg_string": "Yes, thank you."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Anyway, I should be leaving soon."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Wait, you're already going to leave?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yes, I still don't know the secrets of this arm, and there could be people like me somewhere."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "I want to help those people."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "I see... Take care, Nazarus."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Just let me know if anything happens. I'll lend you my strength anytime."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "Thank you. Farewell."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Sophie, thank you, I really mean it. I was able to fulfill one of my goals."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "No need for thanks, I'm just glad I could help."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x18,
            "msg_string": "...Um, are you going to set off on your next journey too?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x19,
            "msg_string": "Well, I intend to leave after some time, but not anytime soon."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1a,
            "msg_string": "I still have many things to investigate around this area."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x1b,
            "msg_string": "That means we'll be working together for a while longer."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
