{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_JUL_040.ebm",
    "nb_messages": 0x18,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Sophie."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Sir Julio, are you looking for something?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x2,
            "msg_string": "Yes, I'm checking the types of books circulating in this area."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "The types of books?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0x4,
            "msg_string": "Different nations and regions have books with different contents. Bookstores reveal the traits of an area."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "Hm, is that so?"
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "That's very interesting. I've never seen another bookstore."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x7,
            "msg_string": "Bookstores in the big city are very large. They contain an abundance of different books as a result."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "That makes sense."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "But it's rare to see such an abundant variety of books in a bookstore out in the countryside."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Hehe, thank you."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Huh, I'm interested in how they differ..."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Let's see, the academic books are fairly similar wherever you go, but the cook books are quite different!"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "Cooking...?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "The ingredients you can acquire differ from place to place. Tastes also vary between regions."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I see."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "Oh, I seem to have stayed for too long. I'll return again."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Yes, I look forward to your next visit."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Sir Julio isn't just training as a knight, he's also studying. It sounds like hard work."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "It does. He seems to read quite a lot of books."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Hmm, I don't really like studying..."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x15,
            "msg_string": "But you're studying alchemy?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x16,
            "msg_string": "Alchemy doesn't feel like studying. I don't mind reading those books."
        },
        {
            "type": 0x2,
            "voice_id": 0xc,
            "name_id": 0xc,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x17,
            "msg_string": "Hehe, I see."
        }
    ]
}