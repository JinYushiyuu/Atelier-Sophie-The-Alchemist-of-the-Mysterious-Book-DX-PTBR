{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_JUL_060.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Oh, it's Monika and Sir Julio."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "What were you talking about?"
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Hello, Sophie. Monika was asking me about church choirs."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x3,
            "msg_string": "Wait, choirs?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "I was interested in it. We only sing on special days at our church."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I was asking Sir Julio about what they do in other towns."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2e,
            "expr_id": 0x4,
            "msg_id": 0x6,
            "msg_string": "Huh..."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "I know I told you before, but churches differ between cities."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "If a church is putting more effort into their choir, sometimes they go to sing in all kinds of different places."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "I see, so they do that in some cities."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0xa,
            "msg_string": "Was I of use?"
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "Yes, very much so. Thank you very much."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "That's good. By the way, you should consider joining a choir, Monika."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xd,
            "msg_string": "I'm sure you would be welcome anywhere with your voice."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yeah, I think so too."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "Thank you, but I'm still thinking about it."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0x10,
            "msg_string": "I see. If there's anything I can help with, don't hesitate to ask. I'll do what I can."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Thank you very much. I'll ask, if the time comes."
        },
        {
            "type": 0x2,
            "voice_id": 0x2,
            "name_id": 0x2,
            "extra_id": 0x42,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Anyway, I have something to do now. See you two later."
        },
        {
            "type": 0x2,
            "voice_id": 0x4,
            "name_id": 0x4,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x13,
            "msg_string": "Yes."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "See you."
        }
    ]
}