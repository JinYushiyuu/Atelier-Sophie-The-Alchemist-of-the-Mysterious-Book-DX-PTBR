{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC03_JUL_190.ebm",
    "nb_messages": 0x15,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Yes?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Excuse me."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Oh, Nazarus! Is your arm feeling okay?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0xd,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "Yes, thanks to the medicine you made. I'd like to thank you again."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "Ehehe, I'm glad."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "What did you come here for today?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0xe,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "To tell the truth, I'd like you to make that medicine again."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "Huh? Again?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0xf,
            "expr_id": 0x0,
            "msg_id": 0x8,
            "msg_string": "I'm thinking of going on a journey. I'd like to have it, just in case."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x9,
            "msg_string": "Also, I'm sure there are people in other places who are suffering just as I did."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2c,
            "expr_id": 0x4,
            "msg_id": 0xa,
            "msg_string": "If I happen to meet them while I search for a way to fix my arm, I want to help."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I see... I understand."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x2d,
            "expr_id": 0x4,
            "msg_id": 0xc,
            "msg_string": "Thank you. When you're done making it, please bring it to that laboratory."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2a,
            "expr_id": 0x3,
            "msg_id": 0xd,
            "msg_string": "What!? You're still staying in that place?"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Yes, I was researching the documents there. I think I'll understand what that place was intended for soon."
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x69,
            "expr_id": 0x0,
            "msg_id": 0xf,
            "msg_string": "I'll probably be finished by the time you deliver the medicine. I'll explain it all to you then."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x3c,
            "expr_id": 0x0,
            "msg_id": 0x10,
            "msg_string": "I got it!"
        },
        {
            "type": 0x2,
            "voice_id": 0x11a,
            "name_id": 0x11,
            "extra_id": 0x6b,
            "expr_id": 0x0,
            "msg_id": 0x11,
            "msg_string": "Alright, thanks again."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x12,
            "msg_string": "Okay then, I should Synthesize it."
        },
        {
            "type": 0x2,
            "voice_id": 0x1,
            "name_id": 0x1,
            "extra_id": 0x2b,
            "expr_id": 0x4,
            "msg_id": 0x13,
            "msg_string": "Nazarus said he would be going on a journey, so you should probably make a large amount."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x14,
            "msg_string": "Yeah. I need to make lots of it, so he can give it to lots of people!"
        }
    ]
}