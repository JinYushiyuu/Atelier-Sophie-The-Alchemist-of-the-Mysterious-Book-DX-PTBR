        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x7,
            "msg_string": "It's not just metals. I can make anything!"
