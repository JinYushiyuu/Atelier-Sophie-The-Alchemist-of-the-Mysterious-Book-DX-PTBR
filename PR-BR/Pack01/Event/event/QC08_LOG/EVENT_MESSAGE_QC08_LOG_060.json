            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x4e,
            "expr_id": 0x0,
            "msg_id": 0x9,
            "msg_string": "Well... \"Anything\" is an exaggeration... I'm sorry. I can't make THAT much yet."
