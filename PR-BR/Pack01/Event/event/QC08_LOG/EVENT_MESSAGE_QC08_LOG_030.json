{
    "json_version": 0x2,
    "name": "EVENT_MESSAGE_QC08_LOG_030.ebm",
    "nb_messages": 0x10,
    "messages": [
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "expr_id": 0x0,
            "msg_id": 0x0,
            "msg_string": "Hello, Logy."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0x1,
            "msg_string": "Hey there, Sophie. Do you want some new weapons?"
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x30,
            "expr_id": 0x0,
            "msg_id": 0x2,
            "msg_string": "Yeah, pretty much... But you seem really busy right now."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x5,
            "expr_id": 0x0,
            "msg_id": 0x3,
            "msg_string": "No, I was just putting the finishing touches onto this. I'm about to be done with it."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x32,
            "expr_id": 0x0,
            "msg_id": 0x4,
            "msg_string": "The weapons you make are really amazing... They're strong and pretty."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3d,
            "expr_id": 0x0,
            "msg_id": 0x5,
            "msg_string": "I'm happy you said that, but I still have a long ways to go."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x34,
            "expr_id": 0x0,
            "msg_id": 0x6,
            "msg_string": "Wait, really? From my point of view, I think everything you make is amazing..."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1c,
            "expr_id": 0x3,
            "msg_id": 0x7,
            "msg_string": "Well, for example, this sword. The polish on the blade is subpar."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x8,
            "msg_string": "The hilt is also uneven and misshapen."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1d,
            "expr_id": 0x3,
            "msg_id": 0x9,
            "msg_string": "There's a lot more things about it that I can point out."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1e,
            "expr_id": 0x3,
            "msg_id": 0xa,
            "msg_string": "Once you see the techniques of real craftsmen, I look like an amateur."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x43,
            "expr_id": 0x0,
            "msg_id": 0xb,
            "msg_string": "I didn't know... I couldn't tell at all, but it sounds like you're really serious about this."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x1,
            "expr_id": 0x0,
            "msg_id": 0xc,
            "msg_string": "Of course I am. This is my business, naturally I want to provide the best products I can to my customers."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xd,
            "msg_string": "People would know if I half-assed my job or rushed through forging my wares."
        },
        {
            "type": 0x2,
            "voice_id": 0x9,
            "name_id": 0x9,
            "extra_id": 0x3,
            "expr_id": 0x0,
            "msg_id": 0xe,
            "msg_string": "Even if I was able to stay in business, I'd be a failure as a craftsman."
        },
        {
            "type": 0x2,
            "voice_id": 0x0,
            "name_id": 0x0,
            "extra_id": 0x2b,
            "expr_id": 0xffffffff,
            "msg_id": 0xf,
            "msg_string": "(...Logy is really amazing. I need to work harder at my alchemy too.)"
        }
    ]
}