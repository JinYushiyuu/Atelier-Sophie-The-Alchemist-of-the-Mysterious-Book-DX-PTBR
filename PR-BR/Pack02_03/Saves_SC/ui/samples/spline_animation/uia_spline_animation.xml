<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uia.dtd">
<root>
	<anim name="anm_spline_pos">
		<curve attr="pos" interpolate="spline" >
			<key time="0.0"		value="-100, -100, 0, 0"/>
			<key time="1.0"		value="100, -100, 0, 0"/>
			<key time="2.0"		value="100, 100, 0, 0"/>
			<key time="3.0"		value="-100, 100, 0, 0"/>
			<key time="4.0"		value="-100, -100, 0, 0"/>
		</curve>
	</anim>
	<anim name="anm_linear_pos">
		<curve attr="pos" interpolate="linear" >
			<key time="0.0"		value="-100, -100, 0, 0"/>
			<key time="1.0"		value="100, -100, 0, 0"/>
			<key time="2.0"		value="100, 100, 0, 0"/>
			<key time="3.0"		value="-100, 100, 0, 0"/>
			<key time="4.0"		value="-100, -100, 0, 0"/>
		</curve>
	</anim>
	<anim name="anm_spline_pos_edging">
		<curve attr="pos" interpolate="spline" >
			<key time="0.0"		value="-100, -100, 0, 0" edging="0.5"/>
			<key time="1.0"		value="100, -100, 0, 0" edging="0.5"/>
			<key time="2.0"		value="100, 100, 0, 0" edging="0.5"/>
			<key time="3.0"		value="-100, 100, 0, 0" edging="0.5"/>
			<key time="4.0"		value="-100, -100, 0, 0" edging="0.5"/>
		</curve>
	</anim>

	<anim name="anm_spline_pos_easing">
		<curve attr="pos" interpolate="spline" >
			<key time="0.0"		value="-100, -100, 0, 0" easing="1.0"/>
			<key time="1.0"		value="100, -100, 0, 0" easing="1.0"/>
			<key time="2.0"		value="100, 100, 0, 0" easing="1.0"/>
			<key time="3.0"		value="-100, 100, 0, 0" easing="1.0"/>
			<key time="4.0"		value="-100, -100, 0, 0" easing="1.0"/>
		</curve>
	</anim>

</root>

