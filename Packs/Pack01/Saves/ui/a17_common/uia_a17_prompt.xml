<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uia.dtd">
<root>
    <!-- Y軸360度回転 -->
	<anim name="anm_prompt_rotateZ360">
		<curve attr="rot">
			<key time="0.0"		value="0,0,0"/>
			<key time="1.0"		value="0,0,360"/>
		</curve>
	</anim>

	<anim name="anm_prompt_image">
		<curve attr="image_no">
			<key time="0.0"		value="0"/>
			<key time="1.0"		value="17"/>
			<key time="1.05"		value="17"/>
		</curve>
	</anim>

	<anim name="anm_prompt_scale">
		<curve attr="scale">
			<key time="0.0"		value="0,0,1"/>
			<key time="1.0"		value="1,1,1"/>
			<key time="1.05"		value="1,1,1"/>
		</curve>
		<curve attr="color">
			<key time="0.0"		value="255,255,255,255"/>
			<key time="0.7"		value="255,255,255,255"/>
			<key time="1.0"		value="255,255,255,0"/>
			<key time="1.05"	value="255,255,255,0"/>
		</curve>
	</anim>

</root>

