<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uil.dtd">
<!-- 
    clone_treeとclone_child_treeのサンプルです。    
-->
<root>
    <text color="255,255,192,255" pos="100,80" text="元となる階層構造"/>
    <node pos="100,100">
        <text pos="20,10" name="text_1st" text="text_1st">
            <text pos="20,25" text="text_2nd">
                <text pos="20,25" text="text_3rd"/>
            </text>
            <text pos="20,90" text="text_4th">
                <text pos="20,25" text="text_5th"/>
            </text>
        </text>
    </node>

    <!-- clone_tree -->
    <text color="192,255,255,255" pos="100,330" text="text_1stをclone_treeしたもの"/>
    <node pos="100,350" clone_tree="text_1st"/>

    <!-- clone_child_tree -->
    <text color="192,255,255,255" pos="500,330" text="text_1stをclone_child_treeしたもの"/>
    <node pos="500,350" clone_child_tree="text_1st"/>
</root>

