<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!DOCTYPE root SYSTEM "file://st01/project/A17/_Programmer/ui/uil.dtd">
<root>
	<!--***↓お決まり関連(必ず一番上に置いておく) ***-->
	<node name="usuals" visible="false" viewer_visible="false">
		<!--↓テンプレート(文字色やカスタムフォント)の読み込み-->
		<node load="Saves/ui/uil_template.xml" name="font_template"/>
	</node>
	<!--***↓指示書画像(Data/Win32/ui_bg/ui_bg_sample_g1t) ***-->
	<image name="ui_bg" style="common_bg_sample" visible="false" viewer_visible="false" color="255.00, 255.00, 255.00, 128.00"/>
	<!--***↓クローン元パーツを入れておく場所 ***-->
	<node name="clone_targets" viewer_visible="false" visible="false"/>
	<!--***↓画面パーツの配置場所 ***-->
	<node name="top">
		<node name="caption_g" pos="23.00, -0.00, -0.00" rot="-0.00, -0.00, -0.00" scale="1.00, 1.00, 1.00">
			<image name="caption_bg" style="gen_a17_main_caption02"/>
			<image name="caption" style="gen_a17_main_caption02_cap" pos="55.00, 44.00, 0.00" image_no="36"/>
		</node>
		<anim_ctrl name="fade_in" start_visible="true" viewer_key_assign="0" exclusive_play="true">
			<bind_node node="top" anim="anm_common_fade_in"/>
		</anim_ctrl>
		<anim_ctrl name="fade_out" start_visible="true" reverse="true" viewer_key_assign="1" exclusive_play="true">
			<bind_node node="top" anim="anm_common_fade_in"/>
		</anim_ctrl>
	</node>
</root>
