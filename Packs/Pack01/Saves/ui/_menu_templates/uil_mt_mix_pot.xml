		<scroll_bar name="__uimenu_scroll_bar" pos_ratio="1,0" pos="-41, 25, 0" size_h="244"/>
		<!-- メニュー項目 -->
		<node name="__uimenu_body" pos="-8, 43, 0" viewer_visible="true">
			<!-- メニューカーソル -->
			<node name="__uimenu_cursor" pos="17, 0, 0">
				<image name="__uimenu_cursor_inactive" pos="30.00, -1.00, -10.00" parent_size_copy_w="true" size_copy_w_offset="-75.00" image_no="0" style="gen_window01_highlight_over"/>
