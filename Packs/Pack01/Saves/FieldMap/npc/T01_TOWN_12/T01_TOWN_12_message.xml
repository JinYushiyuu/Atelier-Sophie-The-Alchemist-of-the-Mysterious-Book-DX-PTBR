    <T01_TOWN_12_message message_data="TOWN_12_NPC06A_00" chara_tag="NPC06A" name_tag="NPC06A" voice_no1="11741" message1="If it's just for general use, the weapons being sold are good enough."/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC06A_01" chara_tag="NPC06A" name_tag="NPC06A" voice_no1="-1" message1="..."/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC06A_10" chara_tag="NPC06A" name_tag="NPC06A" voice_no1="11741" message1="If you're having a hard time fighting, you might want to have your weapons custom made." next_message_tag="TOWN_12_NPC06A_11"/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC06A_11" chara_tag="NPC06A" name_tag="NPC06A" voice_no1="-1" message1="For example, the various &quot;Slayer&quot; traits are strong against different types of enemies."/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC06A_20" chara_tag="NPC06A" name_tag="NPC06A" voice_no1="11741" message1="A new weapon isn't always going to be stronger." next_message_tag="TOWN_12_NPC06A_21"/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC06A_21" chara_tag="NPC06A" name_tag="NPC06A" voice_no1="-1" message1="Sometimes it's better to just enhance the weapons you're already used to using."/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC26B_00" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="11742" message1="I'm thinking about what kind of weapon I want to use in the future..." next_message_tag="TOWN_12_NPC26B_01"/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC26B_01" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="Even among swords, there's long swords, great swords, rapiers, and more... It's hard to decide."/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC26B_10" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="11742" message1="I thought spears wouldn't have different types to worry about..." next_message_tag="TOWN_12_NPC26B_11"/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC26B_11" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="But there's types for thrusting, slashing, and sweeping... It's hard to decide."/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC26B_20" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="11742" message1="I thought guns wouldn't have different types to worry about..." next_message_tag="TOWN_12_NPC26B_21"/>
    <T01_TOWN_12_message message_data="TOWN_12_NPC26B_21" chara_tag="NPC26B" name_tag="NPC26B_01" voice_no1="-1" message1="But there are handguns, rifles, shotguns, and more... It's hard to decide."/>
