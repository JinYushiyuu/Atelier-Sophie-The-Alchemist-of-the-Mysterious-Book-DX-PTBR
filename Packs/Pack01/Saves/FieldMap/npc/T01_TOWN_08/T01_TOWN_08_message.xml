    <T01_TOWN_08_message message_data="JULIO_TOWN01_08_1" chara_tag="JULIO" name_tag="JULIO" voice_no1="11710" message1="This town is really peaceful. It must be thanks to strong faith and good education."/>
    <T01_TOWN_08_message message_data="JULIO_TOWN01_08_2" chara_tag="JULIO" name_tag="JULIO" voice_no1="11710" message1="Hey, you seem to be doing well today too. How's your alchemy studies going?"/>
    <T01_TOWN_08_message message_data="JULIO_TOWN01_08_3" chara_tag="JULIO" name_tag="JULIO" voice_no1="11710" message1="I make sure to train every day since I came to this town. I don't want my body to get soft."/>
    <T01_TOWN_08_message message_data="JULIO_TOWN01_08_4" chara_tag="JULIO" name_tag="JULIO" voice_no1="11710" message1="Is there some sort of trick to using items? It seems like you can use any item well, so I was just curious."/>
    <T01_TOWN_08_message message_data="JULIO_TOWN01_08_5" chara_tag="JULIO" name_tag="JULIO" voice_no1="11710" message1="I can protect you. Don't worry, I won't lose to any monster."/>
    <T01_TOWN_08_message message_data="JULIO_TOWN01_08_E" chara_tag="JULIO" name_tag="JULIO" voice_no1="11710" message1="Now then, maybe I should take a walk... No, first I need to finish today's training."/>
    <T01_TOWN_08_message message_data="MONIKA_TOWN01_08_1" chara_tag="MONIKA" name_tag="MONIKA" voice_no1="11708" message1="Oh, Sophie. Do you need something today?"/>
    <T01_TOWN_08_message message_data="MONIKA_TOWN01_08_2" chara_tag="MONIKA" name_tag="MONIKA" voice_no1="11708" message1="We're going outside a lot lately, right? That's why I'm making sure to practice my swordplay every day."/>
    <T01_TOWN_08_message message_data="MONIKA_TOWN01_08_3" chara_tag="MONIKA" name_tag="MONIKA" voice_no1="11708" message1="Is your place turning into a mess again? I'll go and help you clean up sometime."/>
    <T01_TOWN_08_message message_data="MONIKA_TOWN01_08_4" chara_tag="MONIKA" name_tag="MONIKA" voice_no1="11708" message1="Alchemy really is amazing... I didn't think you could turn Plachta into a doll..."/>
    <T01_TOWN_08_message message_data="MONIKA_TOWN01_08_5" chara_tag="MONIKA" name_tag="MONIKA" voice_no1="11708" message1="Hey, Sophie? Do you mind if I visit your atelier sometime? ...I really want to eat some sweets."/>
    <T01_TOWN_08_message message_data="MONIKA_TOWN01_08_E" chara_tag="MONIKA" name_tag="MONIKA" voice_no1="11708" message1="Maybe I'll take a little break. Should I go shopping, or have tea, or... Hmm, so many choices..."/>
    <T01_TOWN_08_message message_data="QC01_MON_010_MONIKA" chara_tag="MONIKA" name_tag="MONIKA" voice_no1="11708" message1="Be careful not to trip and hurt yourself." next_message_tag="QC01_MON_010_PAMELA"/>
