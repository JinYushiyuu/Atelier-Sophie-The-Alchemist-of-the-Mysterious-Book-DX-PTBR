    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_OP_0" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="11781" message1="I'm planning to go hunting outside after making preparations on main street." next_message_tag="TOWN_08_NPC20A_OP_1"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_OP_1" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="-1" message1="Maybe I'll take a look at the requests over at Horst's shop too..."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_00" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="11781" message1="Conditions to be considered a top class adventurer? Let's see..." next_message_tag="TOWN_08_NPC20A_01"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_01" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="-1" message1="First of all, you need to be able to complete requests and make good money."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_10" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="11781" message1="Have you been writing everything into your reference book?" next_message_tag="TOWN_08_NPC20A_11"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_11" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="-1" message1="You'll be top class if you review it from time to time."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_20" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="11781" message1="There's times when you just don't know what to do, right?" next_message_tag="TOWN_08_NPC20A_21"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC20A_21" chara_tag="NPC20A" name_tag="NPC20A_01" voice_no1="-1" message1="In times like that, it might be a good idea to review recent &quot;events&quot;."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23A_00" chara_tag="NPC23A" name_tag="NPC23A" voice_no1="11772" message1="Shopping is really fun." next_message_tag="TOWN_08_NPC23A_01"/>
