    <T01_TOWN_08_message message_data="TOWN_08_NPC23A_10" chara_tag="NPC23A" name_tag="NPC23A" voice_no1="11772" message1="If you really examine the details of things for sale closely..." next_message_tag="TOWN_08_NPC23A_11"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23A_11" chara_tag="NPC23A" name_tag="NPC23A" voice_no1="-1" message1="A lot of times you'll realize that you actually need it."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23A_20" chara_tag="NPC23A" name_tag="NPC23A" voice_no1="11772" message1="Order made goods are great. They're perfectly fitting..." next_message_tag="TOWN_08_NPC23A_21"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23A_21" chara_tag="NPC23A" name_tag="NPC23A" voice_no1="-1" message1="You can choose all kinds of options when ordering too... It's the most luxurious kind of shopping."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23B_00" chara_tag="NPC23B" name_tag="NPC23B" voice_no1="11739" message1="Hmm, I want to buy clothes, but... I don't know what color to choose." next_message_tag="TOWN_08_NPC23B_01"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23B_01" chara_tag="NPC20B" name_tag="NPC20B" voice_no1="11744" message1="They say colors reveal your inner nature... Then maybe this..."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23B_10" chara_tag="NPC23B" name_tag="NPC23B" voice_no1="11739" message1="Hmm, I want to buy gems, but... I don't know what size." next_message_tag="TOWN_08_NPC23B_11"/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23B_11" chara_tag="NPC20B" name_tag="NPC20B" voice_no1="11744" message1="Let's see, if I want to wear it for any occasion... Then maybe this..."/>
    <T01_TOWN_08_message message_data="TOWN_08_NPC23B_20" chara_tag="NPC23B" name_tag="NPC23B" voice_no1="11739" message1="Hmm, I want to buy a weapon for self defense, but I don't know what type." next_message_tag="TOWN_08_NPC23B_21"/>
