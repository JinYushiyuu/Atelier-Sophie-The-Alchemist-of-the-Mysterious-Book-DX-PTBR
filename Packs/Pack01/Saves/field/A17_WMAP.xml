<?xml version="1.0" encoding="SHIFT_JIS" ?>

<root>

<!--カメラ関連-->
	<camera boundary_min="-7.0, 0.0, -7.0" boundary_max="-7.0, 0.0, -7.0" center_position2="0,0,0" zoom_mode="XZ" free_camera="false">
		<area tlPosition="-400.0, 0.0, -400.0" brPosition="400.0, 0.0, 400.0" tag="CLOSELY_Z">
			<point length="15.0" radian="180.0" lookRad="45.0" fov="40.0" diffPosition=" 0.0, 1.0, 0.0" position=" 0.0, 0.0, 0.0" bumper_follow_speed="5.0" zoom_time="1.0" zoom_distance="0.0"/>	
		</area>
	</camera>

<!--ユーザーズーム関連-->
<user_zoom  relative_limit="8.0" />

<!--フォグ関連-->
	<fog start="0.0" end="1000" ambient="0.0" mieG="0.0" rayleighPow="0.0" mieRGB="0.5, 0.3, 1.0, 0.5" rayleighRGB="0.0, 0.7, 0.5, 0.5" />

<!--ライト関連-->
	<light ambient="0.5, 0.5, 0.5, 0.0">
		<param type="PARALLEL" rot="90.0, 0.0, 0.0" color="1.0, 1.0, 1.0, 1.0" />
		<param type="POINT" pos="15.0, -3.0, 19.0" color="1.0, 0.9, 0.9, 1.0" ambient="1.0, 1.0, 1.0, 1.0" att0="0.5" att1="0.0" att2="0.15" range="4.0" />
	</light>
<!--CharaShader-->
	<chara_shader light_dir="2.0, -1.0, -1.0" light_color="0.65, 0.4, 0.3, 0.15" rim_light_dir="2.56, -2.67, 1.0" rim_light_color="0.9, 0.9, 0.0, 0.25" point_light_strength="0.1, 0.0, 0.0, 0.0" />

<!--HDR-->
	<hdr threshold="0.5" glow_add_rate="1.5" />

<!--パターンマップ-->
		<pattern_map speed_u="0.005" speed_v="0.005" area_width="140.0" area_height="140.0" />

<!--遠景モデル関連-->
	<sphere offset="0.0, -20.0, 0.0" scale="1.0, 1.0, 1.0" tracking_camera="true" />

<!--風パラメータ定義ブロック-->
	<wind_root>
		<wind dir="1.0, 0.0, 0.0" power="30.0" freq="10.0" shift="0.0" />
		<wind dir="0.0, 0.0, -1.0" power="30.0" freq="10.0" shift="5.0" />

		<!--ノード揺れの定義ブロック-->
		<n_shaker keyword="xN1_" weight="50.0" axis="5.0, 5.0, 5.0" max_angle="10.0" axis_power="10.0" char_range="1.0" char_power="10.0" />

		<!--頂点揺れの定義ブロック-->
		<v_shaker keyword="xV1_" weight="800.0" root_height="0.0" height="0.5" shake_time="10.0" shift_x="2.0" shift_z="2.0" />
		<v_shaker keyword="xV2_" weight="800.0" root_height="0.0" height="0.5" shake_time="10.0" shift_x="1.0" shift_z="1.0" />
	</wind_root>
</root>
